# ============================================================
# PawMate Egypt — Backend Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# ---- DATABASE ----
DATABASE_URL="postgresql://pawmate:pawmate_secure_password@localhost:5432/pawmate"
POSTGRES_PASSWORD="pawmate_secure_password"

# ---- REDIS ----
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="redis_secure_password"

# ---- MONGODB ----
MONGODB_URL="mongodb://pawmate:mongo_secure_password@localhost:27017/pawmate_social"
MONGO_PASSWORD="mongo_secure_password"

# ---- AUTH ----
# IMPORTANT: Generate strong random secrets (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="REPLACE_WITH_32_CHAR_RANDOM_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_32_CHAR_SECRET"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# AES-256 encryption key for sensitive fields (must be 32 bytes = 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHAR_KEY"

# ---- CLOUDINARY (File Storage) ----
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ---- PAYMOB (Egypt Payment Gateway) ----
PAYMOB_API_KEY="your-paymob-api-key"
PAYMOB_INTEGRATION_ID_CARD="your-card-integration-id"
PAYMOB_INTEGRATION_ID_WALLET="your-wallet-integration-id"
PAYMOB_HMAC_SECRET="your-hmac-secret"

# ---- FIREBASE (Push Notifications) ----
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"

# ---- VONAGE (SMS - OTP) ----
VONAGE_API_KEY="your-vonage-api-key"
VONAGE_API_SECRET="your-vonage-api-secret"
VONAGE_FROM_NUMBER="PawMate"

# ---- RESEND (Email) ----
EMAIL_API_KEY="your-resend-api-key"
EMAIL_FROM="hello@pawmateegypt.com"

# ---- GOOGLE OAUTH ----
GOOGLE_CLIENT_ID_WEB="your-google-client-id"

# ---- FACEBOOK OAUTH ----
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# ---- SENDGRID (Legacy — replaced by Resend) ----
# SENDGRID_API_KEY="your-sendgrid-api-key"
# SENDGRID_FROM_EMAIL="noreply@pawmate.eg"
# SENDGRID_FROM_NAME="PawMate"

# ---- GOOGLE MAPS ----
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ---- APP CONFIG ----
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"

# Platform commission percentage (15 = 15%)
PLATFORM_COMMISSION_PERCENT=15

# Booking request timeout in minutes
BOOKING_TIMEOUT_MINUTES=10

# ---- COMMAND CENTER EVENT BRIDGE ----
COMMAND_CENTER_WEBHOOK_URL="https://command-centr.netlify.app/api/ingest/events"
COMMAND_CENTER_WEBHOOK_SECRET="<set-in-railway-32-byte-hex>"

# ---- FEATURE FLAGS ----
ENABLE_COMMUNITY=false

# ---- OPTIONAL: ERROR TRACKING ----
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
