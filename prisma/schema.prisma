// ============================================================
// PROVIDERS (generic profile for Trainers, Kennels, Groomers, Vets, Shops)
// ============================================================

model ProviderProfile {
  id           String       @id @default(uuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerType ProviderType

  businessName String
  tagline      String?
  description  String?

  address   String?
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  city      String?
  phone     String?

  coverPhotos      String[] @default([])
  verificationDocs String[] @default([])

  serviceMenu    Json?
  operatingHours Json?
  maxCapacity    Int?

  verificationStatus VerificationStatus @default(PENDING)
  isVerified         Boolean            @default(false)
  verifiedAt         DateTime?
  rejectionReason    String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([providerType, isVerified, isActive])
  @@index([city, providerType])
  @@map("provider_profiles")
}

model Product {
  id                String           @id @default(uuid())
  sellerId          String
  seller            User             @relation(fields: [sellerId], references: [id])
  providerProfileId String?
  providerProfile   ProviderProfile? @relation(fields: [providerProfileId], references: [id])

  name          String
  description   String?
  price         Decimal  @db.Decimal(8, 2)
  photos        String[] @default([])
  ingredients   String?
  allergens     String?
  stockQuantity Int      @default(0)
  isAvailable   Boolean  @default(true)
  sellerType    ProviderType

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId, isAvailable])
  @@index([sellerType, isAvailable])
  @@map("products")
}

model Order {
  id       String @id @default(uuid())
  buyerId  String
  buyer    User   @relation("OrderBuyer", fields: [buyerId], references: [id])
  sellerId String
  seller   User   @relation("OrderSeller", fields: [sellerId], references: [id])

  items         OrderItem[]
  totalAmount   Decimal     @db.Decimal(10, 2)
  platformFee   Decimal     @db.Decimal(10, 2)
  sellerEarning Decimal     @db.Decimal(10, 2)

  status          String       // OrderStatus enum values
  deliveryType    String       // DELIVERY | PICKUP
  deliveryAddress String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(8, 2)

  @@map("order_items")
}

