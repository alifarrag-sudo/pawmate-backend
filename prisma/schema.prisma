// ============================================================
// BOOKINGS
// ============================================================

model Booking {
  id           String @id @default(uuid())
  parentId     String                                    // was: ownerId
  parent       User   @relation("BookingParent", fields: [parentId], references: [id])
  petFriendId  String?                                   // null for Kennel/Trainer/PetHotel
  petFriend    User?  @relation("BookingPetFriend", fields: [petFriendId], references: [id])

  // Provider references (only one will be set based on serviceType)
  trainerId    String?
  kennelId     String?
  petHotelId   String?

  bookingType  BookingType
  serviceType  ServiceType
  status       BookingStatus @default(pending)

  // Timing
  requestedStart DateTime
  requestedEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?

  // Location
  serviceLocationType ServiceLocationType
  serviceLat          Decimal?             @db.Decimal(10, 8)
  serviceLng          Decimal?             @db.Decimal(11, 8)
  serviceAddress      String?

  // Pricing
  basePrice        Decimal @db.Decimal(10, 2)
  commissionRate   Decimal @default(15.00) @db.Decimal(5, 2)
  commissionAmount Decimal @db.Decimal(10, 2)
  totalPrice       Decimal @db.Decimal(10, 2)
  providerPayout   Decimal @db.Decimal(10, 2)  // was: sitterPayout
  currency         String  @default("EGP")

  // Overtime (PetFriend bookings)
  overtimeMinutes Int     @default(0)
  overtimeCharge  Decimal @default(0) @db.Decimal(8, 2)

  // Payment
  paymentStatus       PaymentStatus  @default(pending)
  paymentMethod       PaymentMethod?
  paymentReference    String?
  paymentAuthorizedAt DateTime?
  paymentCapturedAt   DateTime?
  paymentRefundedAt   DateTime?
  refundAmount        Decimal?       @db.Decimal(10, 2)
  refundReason        String?

  // Cancellation
  cancelledById      String?
  cancelledBy        User?            @relation("CancelledBy", fields: [cancelledById], references: [id])
  cancelledAt        DateTime?
  cancellationReason String?
  cancellationType   CancellationType?

  // Pickup
  readyForPickupAt  DateTime?
  pickupConfirmedAt DateTime?

  // Instructions
  specialInstructions String?
  parentNotes         String?  // was: ownerNotes

  // Pet snapshot (frozen at booking time)
  petSnapshot Json? // Array of pet summaries

  // Review
  parentReviewed    Boolean  @default(false)  // was: ownerReviewed
  providerReviewed  Boolean  @default(false)  // was: sitterReviewed
  reviewDeadline    DateTime?

  // Routing
  routingAttempt Int    @default(1)
  routingHistory Json   @default("[]")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  pets              BookingPet[]
  extensions        BookingExtension[]
  dispute           BookingDispute?
  tasks             BookingTask[]
  walkSessions      WalkSession[]
  reviews           Review[]
  transactions      PaymentTransaction[]
  payouts           PetFriendPayout[]
  careLogs          CareLog[]
  overtimeLog       OvertimeLog?
  endCode           BookingEndCode?      // 4-digit service end code

  @@index([parentId, status, createdAt(sort: Desc)])
  @@index([petFriendId, status, createdAt(sort: Desc)])
  @@index([status, requestedStart])
  @@index([petFriendId])
  @@index([paymentStatus])
  @@index([parentId, status])
  @@map("bookings")
}

// 4-digit service end code — shown only to Parent, entered by PetFriend to end service
model BookingEndCode {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  code      String   // 4-digit string e.g. "4821"
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("booking_end_codes")
}

model BookingPet {
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  petId     String
  pet       Pet     @relation(fields: [petId], references: [id])

  @@id([bookingId, petId])
  @@map("booking_pets")
}

model BookingExtension {
  id              String          @id @default(uuid())
  bookingId       String
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requestedById   String
  newEndTime      DateTime
  additionalPrice Decimal?        @db.Decimal(10, 2)
  reason          String?
  status          ExtensionStatus @default(pending)
  respondedAt     DateTime?
  createdAt       DateTime        @default(now())

