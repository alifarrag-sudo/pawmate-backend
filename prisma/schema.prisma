// ============================================================
// OPERATOR / BUSINESS PROFILES (Prompt 10)
// ============================================================

model BusinessProfile {
  id                   String         @id @default(cuid())
  ownerId              String         @unique
  owner                User           @relation(fields: [ownerId], references: [id])

  // Identity
  businessName         String
  businessType         BusinessType
  description          String?        @db.Text
  logoUrl              String?
  coverPhotoUrl        String?
  photosUrls           String[]       @default([])

  // Legal
  commercialRegNumber  String?
  taxCard              String?        // Cloudinary URL for tax card doc
  commercialRegDocUrl  String?

  // Contact
  businessEmail        String
  businessPhone        String
  whatsappNumber       String?
  websiteUrl           String?

  // Location
  primaryAddress       String
  primaryCity          String
  primaryLat           Float?
  primaryLng           Float?
  branches             BusinessBranch[]

  // Services offered (roll-up of team)
  servicesJson         Json?          // aggregated view of what team can do

  // Tier (team size limits)
  businessTier         String         @default("FREE") // "FREE" or "PREMIUM"

  // Status
  status               BusinessStatus @default(PENDING_DOCS)
  appliedAt            DateTime       @default(now())
  autoApprovedAt       DateTime?
  adminReviewedAt      DateTime?

  // Reputation (aggregated from team)
  totalBookings        Int            @default(0)
  averageRating        Float?

  // Team
  teamMembers          TeamMember[]
  invites              TeamInvite[]

  // Kennel-specific profile (Prompt 12)
  kennelProfile        KennelProfile?

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([primaryCity])
  @@index([status])
  @@index([businessType])
  @@map("business_profiles")
}

model BusinessBranch {
  id          String          @id @default(cuid())
  businessId  String
  business    BusinessProfile @relation(fields: [businessId], references: [id])
  name        String
  address     String
  city        String
  lat         Float?
  lng         Float?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())

  @@index([businessId])
  @@map("business_branches")
}

model TeamMember {
  id                    String           @id @default(cuid())
  businessId            String
  business              BusinessProfile  @relation(fields: [businessId], references: [id])
  userId                String
  user                  User             @relation("TeamMemberships", fields: [userId], references: [id])

  role                  TeamRole         @default(PROVIDER)
  providerType          ProviderType     // PETFRIEND or TRAINER
  providerProfileId     String?          // links to PetFriendProfile or TrainerProfile

  // Permissions granted by operator
  canAcceptBookings     Boolean          @default(true)
  canSetOwnAvailability Boolean          @default(true)
  canMessageParents     Boolean          @default(true)
  canWithdrawEarnings   Boolean          @default(true) // if false: operator manages payouts

  // Status
  status                TeamMemberStatus @default(ACTIVE)
  joinedAt              DateTime         @default(now())
  suspendedAt           DateTime?
  suspendedReason       String?
  removedAt             DateTime?

  // Assignment
  assignedBranchId      String?

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@map("team_members")
}

model TeamInvite {
  id                 String          @id @default(cuid())
  businessId         String
  business           BusinessProfile @relation(fields: [businessId], references: [id])
  inviteCode         String          @unique
  inviteLinkUrl      String?         // full deep-link URL
  invitedEmail       String?         // optional; if set, invite pre-fills on signup
  invitedPhone       String?
  invitedName        String?
  targetRole         TeamRole        @default(PROVIDER)
  targetProviderType ProviderType    @default(PETFRIEND)

  createdBy          String          // userId of operator/manager who created
  createdAt          DateTime        @default(now())
  expiresAt          DateTime        // default 7 days from creation
  usedAt             DateTime?
  usedByUserId       String?
  status             InviteStatus    @default(PENDING)

  @@index([inviteCode])
  @@index([businessId, status])
  @@map("team_invites")
}

// ============================================================
// REFERRALS
// ============================================================

enum ReferralStatus {
  PENDING        // code shared, not yet used
  SIGNED_UP      // referee signed up with code
  QUALIFIED      // referee completed qualifying event
  REWARDED       // referrer received reward
  EXPIRED        // 90 days no action
}

model Referral {
  id                String         @id @default(cuid())
  referrerUserId    String
  referrer          User           @relation("ReferralsMade", fields: [referrerUserId], references: [id])
  referralCode      String
  refereeUserId     String?
  referee           User?          @relation("ReferralsReceived", fields: [refereeUserId], references: [id])
  refereeRole       String?        // "PARENT" or "PETFRIEND"
  status            ReferralStatus @default(PENDING)
  rewardEgp         Int            @default(0)
  rewardType        String?        // "CREDIT" or "CASH"
  qualifyingEventId String?        // booking ID that qualified the referral
  createdAt         DateTime       @default(now())
  qualifiedAt       DateTime?
  rewardedAt        DateTime?

  @@index([referrerUserId])
  @@index([referralCode])
  @@index([refereeUserId])
  @@index([status])
  @@map("referrals")
}

// ============================================================
// WEB PLATFORM SUPPORT (PawMateHub web — Prompt 10.5)
// ============================================================

enum ContactType {
  PARENT
  PROVIDER
  BUSINESS
  PRESS
  OTHER
}

model ContactSubmission {
  id        String      @id @default(uuid())
  name      String
  email     String
  type      ContactType
  message   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([email])
  @@index([type, createdAt(sort: Desc)])
  @@map("contact_submissions")
}

model WebApplicationDraft {
  id        String    @id @default(uuid())
  userId    String?   @unique  // null for guest applications
  email     String?   @unique  // guest identifier when userId is null
  step      Int       @default(1)
  data      Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([email])
  @@map("web_application_drafts")
}
