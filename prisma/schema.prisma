  savingsVsAlaCarte Int?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  stays PetHotelStay[]

  @@index([petHotelProfileId])
  @@map("pethotel_packages")
}

model PetHotelStay {
  id                String           @id @default(cuid())
  bookingId         String           @unique
  booking           Booking          @relation(fields: [bookingId], references: [id])
  petHotelProfileId String
  petHotelProfile   PetHotelProfile  @relation(fields: [petHotelProfileId], references: [id])
  petHotelRoomId    String?
  petHotelRoom      PetHotelRoom?    @relation(fields: [petHotelRoomId], references: [id])
  packageId         String?
  package           PetHotelPackage? @relation(fields: [packageId], references: [id])

  checkInDate      DateTime
  checkOutDate     DateTime
  actualCheckInAt  DateTime?
  actualCheckOutAt DateTime?

  depositAmountEgp Int
  depositPaidAt    DateTime?
  balanceAmountEgp Int
  balancePaidAt    DateTime?

  intakePhotos                String[]  @default([])
  intakeWeight                Decimal?  @db.Decimal(5, 2)
  intakeNotes                 String?   @db.Text
  vaccinationDocsUrls         String[]  @default([])
  liabilityWaiverSignedAt     DateTime?
  liabilityWaiverVersion      Int?
  liabilityWaiverSignatureUrl String?

  dailyUpdatesJson Json?

  groomingSessionsDone Int     @default(0)
  trainingSessionsDone Int     @default(0)
  vetCheckupDone       Boolean @default(false)

