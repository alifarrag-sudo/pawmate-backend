// PawMate Egypt — Restructured Prisma Schema
// Restructure branch: feature/app-restructure
// Run: npx prisma migrate dev --name restructure_roles_and_profiles

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

