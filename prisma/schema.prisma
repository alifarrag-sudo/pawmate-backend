// drop_in removed per restructure
// Service taxonomy: SERVICES / PROFESSIONAL_SERVICES / PET_CARE_SERVICES / MARKETPLACE
enum ServiceCategory {
  SERVICES // PetFriend individual services: BOARDING, WALKING, DAY_CARE
  PROFESSIONAL_SERVICES // Verified businesses: KENNEL, PET_HOTEL, TRAINING
  PET_CARE_SERVICES // Licensed: VET, GROOMING
  MARKETPLACE // PET_SHOP product orders
}

enum ServiceType {
  // SECTION A — SERVICES (PetFriend individual)
  BOARDING // overnight stay (replaces overnight_stay)
  WALKING // hourly leash walks (replaces dog_walking)
  DAY_CARE // daytime supervision, 6hr/8hr (replaces pet_watching_*)

  // SECTION B — PROFESSIONAL SERVICES
  KENNEL // commercial boarding facility (replaces kennel_boarding)
  PET_HOTEL // premium accommodation (replaces pethotel_boarding)
  TRAINING // certified trainers (replaces trainer_session)

  // SECTION C — PET CARE SERVICES
  VET // veterinary
  GROOMING // grooming salon/van

  // SECTION D — MARKETPLACE
  PET_SHOP // shop product order

  // Legacy values kept for migration backfill — DO NOT use for new bookings.
  // These will be removed in a follow-up migration once historical rows are reconciled.
  dog_walking // legacy → WALKING
  pet_watching_hourly // legacy → DAY_CARE
  pet_watching_daily // legacy → DAY_CARE
  overnight_stay // legacy → BOARDING
  trainer_session // legacy → TRAINING
  kennel_boarding // legacy → KENNEL
  pethotel_boarding // legacy → PET_HOTEL
}

