// PawMate Egypt - Full Prisma Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  user
  admin
}

enum ActiveRole {
  owner
  sitter
}

enum LoyaltyTier {
  bronze
  silver
  gold
  platinum
}

enum Species {
  dog
  cat
  bird
  rabbit
  reptile
  fish
  hamster
  guinea_pig
  other
}

enum PetGender {
  male
  female
  unknown
}

enum WeightCategory {
  small    // < 5kg
  medium   // 5-15kg
  large    // 15-30kg
  xlarge   // > 30kg
}

enum MedicationFrequency {
  once_daily
  twice_daily
  three_daily
  four_daily
  every_other_day
  weekly
  as_needed
}

enum ScheduleType {
  feeding
  walk
  medication
  grooming
  other
}

enum BehaviorCompatibility {
  yes
  no
  with_supervision
}

enum TrainingLevel {
  none
  basic
  advanced
}

enum ServiceType {
  dog_walking
  drop_in
  daycare
  overnight_boarding
  house_sitting
}

enum BookingType {
  hourly
  daily
  weekly
  monthly
}

enum BookingStatus {
  pending
  accepted
  active
  completed
  cancelled
  disputed
  no_sitters_available
}

enum PaymentStatus {
  pending
  authorized
  captured
  refunded
  partially_refunded
  failed
  voided
}

enum PaymentMethod {
  card
  mobile_wallet
  fawry
  platform_wallet
}

enum ServiceLocationType {
  owner_home
  sitter_home
  custom
}

enum CancellationType {
  owner_24h_plus
  owner_24h_minus
  owner_1h_minus
  owner_noshow
  sitter_cancel
  sitter_noshow
  admin_cancel
}

enum ExtensionStatus {
  pending
  accepted
  declined
  expired
}

enum DisputeCategory {
  service_not_rendered
  pet_injured
  property_damage
  late_no_show
  overcharged
  other
}

enum DisputeStatus {
  open
  under_review
  resolved
  appealed
  closed
}

enum DisputeResolution {
  refund_owner
  pay_sitter
  partial_resolution
  no_action
}

enum TaskType {
  feeding
  walk
  medication
  grooming
  check_in
  other
}

enum TaskStatus {
  pending
  completed
  missed
  skipped
}

enum TransactionType {
  booking_payment
  payout
  refund
  top_up
  commission
  compensation
  platform_credit
}

enum TransactionDirection {
  debit
  credit
}

enum TransactionStatus {
  pending
  processing
  success
  failed
}

enum PaymentGateway {
  paymob
  vodafone_cash
  orange_cash
  fawry
  instapay
  platform
}

enum PayoutMethod {
  bank_transfer
  vodafone_cash
  orange_cash
  platform_wallet
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
}

enum RevieweeType {
  owner
  sitter
}

enum ModerationAction {
  approved
  edited
  removed
}

enum PlaceCategory {
  park
  cafe
  clinic
  hotel
  store
  event_space
  other
}

enum Language {
  ar
  en
}

enum Gender {
  male
  female
  prefer_not_to_say
}

enum DeviceType {
  ios
  android
}

// ============================================================
// USERS
// ============================================================

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  firstName    String
  lastName     String
  displayName  String?
  profilePhoto String?
  dateOfBirth  DateTime?
  gender       Gender?
  role         UserRole @default(user)

  // Dual role
  isOwner      Boolean    @default(true)
  isSitter     Boolean    @default(false)
  activeRole   ActiveRole @default(owner)

  // Verification
  idVerified      Boolean   @default(false)
  idFrontUrl      String?
  idBackUrl       String?
  idSelfieUrl     String?
  idNumber        String?   // Encrypted Egyptian National ID
  idReviewedAt    DateTime?
  idReviewedById  String?
  idReviewer      User?     @relation("IdReviewer", fields: [idReviewedById], references: [id])
  idReviewees     User[]    @relation("IdReviewer")

  // Status
  isActive      Boolean   @default(true)
  isBanned      Boolean   @default(false)
  banReason     String?
  banExpiresAt  DateTime?
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(true)

  // Loyalty
  loyaltyPoints Int         @default(0)
  loyaltyTier   LoyaltyTier @default(bronze)

  // Wallet
  walletBalance Decimal  @default(0.00) @db.Decimal(10, 2)
  currency      String   @default("EGP")

  // Preferences
  language     Language @default(ar)
  pushEnabled  Boolean  @default(true)
  smsEnabled   Boolean  @default(true)
  emailEnabled Boolean  @default(true)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  deletedAt   DateTime? // Soft delete

  // Relations
  refreshTokens     RefreshToken[]
  devices           UserDevice[]
  savedLocations    UserLocation[]
  sitterProfile     SitterProfile?
  pets              Pet[]
  bookingsAsOwner   Booking[]      @relation("BookingOwner")
  bookingsAsSitter  Booking[]      @relation("BookingSitter")
  paymentTransactions PaymentTransaction[]
  payouts           SitterPayout[]
  reviewsGiven      Review[]       @relation("Reviewer")
  reviewsReceived   Review[]       @relation("Reviewee")
  notifications     Notification[]
  followedBy        Follow[]       @relation("Followee")
  following         Follow[]       @relation("Follower")
  loyaltyTransactions LoyaltyTransaction[]
  adminActions      AdminAction[]  @relation("AdminActor")
  cancelledBookings Booking[]      @relation("CancelledBy")

  @@index([phone])
  @@index([email])
  @@index([idVerified, isActive, isBanned])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String
  deviceId    String?
  ipAddress   String?
  userAgent   String?
  isRevoked   Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model UserDevice {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken    String?
  deviceType  DeviceType
  deviceModel String?
  appVersion  String?
  osVersion   String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([fcmToken])
  @@map("user_devices")
}

model UserLocation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String   // "Home", "Work", custom
  addressLine String
  city        String?
  district    String?
  lat         Decimal  @db.Decimal(10, 8)
  lng         Decimal  @db.Decimal(11, 8)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("user_locations")
}

// ============================================================
// SITTER PROFILES
// ============================================================

model SitterProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String?
  experienceYears  Int      @default(0)
  services         String[] // ServiceType values
  petTypes         String[] // Species values
  petSizes         String[] // WeightCategory values
  maxPetsPerBooking Int     @default(3)

  // Pricing (EGP)
  hourlyRate  Decimal? @db.Decimal(8, 2)
  dailyRate   Decimal? @db.Decimal(8, 2)
  weeklyRate  Decimal? @db.Decimal(8, 2)
  monthlyRate Decimal? @db.Decimal(8, 2)
  extraPetFee Decimal  @default(0) @db.Decimal(8, 2)

  // Location
  lat             Decimal? @db.Decimal(10, 8)
  lng             Decimal? @db.Decimal(11, 8)
  serviceRadiusKm Int      @default(5)
  addressCity     String?
  addressDistrict String?

  // Availability
  instantBook Boolean @default(false)

  // Performance Metrics (updated by cron)
  avgRating        Decimal @default(0.00) @db.Decimal(3, 2)
  totalReviews     Int     @default(0)
  totalBookings    Int     @default(0)
  responseRate     Decimal @default(100.00) @db.Decimal(5, 2)
  avgResponseMin   Int     @default(0)
  reliabilityScore Decimal @default(100.00) @db.Decimal(5, 2)
  cancellationRate Decimal @default(0.00) @db.Decimal(5, 2)

  // Badges
  isVerified      Boolean @default(false)
  hasPoliceCheck  Boolean @default(false)
  isSuperSitter   Boolean @default(false)
  isFeatured      Boolean @default(false)

  // Status
  isActive       Boolean  @default(true)
  isOnHoliday    Boolean  @default(false)
  holidayEndDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  availabilityTemplates  SitterAvailabilityTemplate[]
  availabilityOverrides  SitterAvailabilityOverride[]
  certifications         SitterCertification[]

  @@index([lat, lng])
  @@index([isActive, isVerified])
  @@map("sitter_profiles")
}

model SitterAvailabilityTemplate {
  id        String        @id @default(uuid())
  sitterId  String
  sitter    SitterProfile @relation(fields: [sitterId], references: [id], onDelete: Cascade)
  dayOfWeek Int           // 0=Sun, 6=Sat
  startTime String        // "09:00"
  endTime   String        // "18:00"
  createdAt DateTime      @default(now())

  @@index([sitterId])
  @@map("sitter_availability_templates")
}

model SitterAvailabilityOverride {
  id           String        @id @default(uuid())
  sitterId     String
  sitter       SitterProfile @relation(fields: [sitterId], references: [id], onDelete: Cascade)
  overrideDate DateTime      @db.Date
  isAvailable  Boolean
  startTime    String?
  endTime      String?
  reason       String?
  createdAt    DateTime      @default(now())

  @@index([sitterId, overrideDate])
  @@map("sitter_availability_overrides")
}

model SitterCertification {
  id          String        @id @default(uuid())
  sitterId    String
  sitter      SitterProfile @relation(fields: [sitterId], references: [id], onDelete: Cascade)
  certName    String
  issuedBy    String?
  issueDate   DateTime?     @db.Date
  expiryDate  DateTime?     @db.Date
  documentUrl String?
  isVerified  Boolean       @default(false)
  verifiedById String?
  createdAt   DateTime      @default(now())

  @@map("sitter_certifications")
}

// ============================================================
// PETS
// ============================================================

model Pet {
  id            String         @id @default(uuid())
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  species       Species
  breed         String?
  color         String?
  dateOfBirth   DateTime?      @db.Date
  weightKg      Decimal?       @db.Decimal(5, 2)
  weightCategory WeightCategory?
  gender        PetGender      @default(unknown)
  isNeutered    Boolean        @default(false)
  microchipId   String?
  profilePhoto  String?
  photos        String[]
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  medicalInfo   PetMedicalInfo?
  vaccinations  PetVaccination[]
  medications   PetMedication[]
  behavior      PetBehavior?
  schedules     PetSchedule[]
  bookingPets   BookingPet[]
  petReviews    PetReview[]
  bookingTasks  BookingTask[]

  @@index([ownerId])
  @@map("pets")
}

model PetMedicalInfo {
  id                    String   @id @default(uuid())
  petId                 String   @unique
  pet                   Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  allergies             String[]
  medicalNotes          String?
  vetName               String?
  vetClinic             String?
  vetPhone              String?
  vetAddress            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRel   String?
  altVetName            String?
  altVetPhone           String?
  updatedAt             DateTime @updatedAt

  @@map("pet_medical_info")
}

model PetVaccination {
  id               String   @id @default(uuid())
  petId            String
  pet              Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  vaccineName      String
  administeredDate DateTime @db.Date
  expiryDate       DateTime? @db.Date
  documentUrl      String?
  notes            String?
  createdById      String?
  createdAt        DateTime @default(now())

  @@index([petId])
  @@index([expiryDate]) // For expiry reminders
  @@map("pet_vaccinations")
}

model PetMedication {
  id          String               @id @default(uuid())
  petId       String
  pet         Pet                  @relation(fields: [petId], references: [id], onDelete: Cascade)
  name        String
  dosage      String?
  unit        String?
  frequency   MedicationFrequency
  adminTimes  String[]             // ["08:00", "20:00"]
  startDate   DateTime?            @db.Date
  endDate     DateTime?            @db.Date
  notes       String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())

  @@index([petId, isActive])
  @@map("pet_medications")
}

model PetBehavior {
  id               String                @id @default(uuid())
  petId            String                @unique
  pet              Pet                   @relation(fields: [petId], references: [id], onDelete: Cascade)
  temperamentTags  String[]
  goodWithDogs     BehaviorCompatibility @default(yes)
  goodWithCats     BehaviorCompatibility @default(yes)
  goodWithKids     BehaviorCompatibility @default(yes)
  trainingLevel    TrainingLevel         @default(none)
  behaviorNotes    String?
  fearTriggers     String[]
  updatedAt        DateTime              @updatedAt

  @@map("pet_behavior")
}

model PetSchedule {
  id              String       @id @default(uuid())
  petId           String
  pet             Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  scheduleType    ScheduleType
  scheduledTime   String       // "08:00" (time of day)
  durationMinutes Int?
  notes           String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([petId, isActive])
  @@map("pet_schedules")
}

// ============================================================
// BOOKINGS
// ============================================================

model Booking {
  id      String @id @default(uuid())
  ownerId String
  owner   User   @relation("BookingOwner", fields: [ownerId], references: [id])
  sitterId String
  sitter  User   @relation("BookingSitter", fields: [sitterId], references: [id])

  bookingType  BookingType
  serviceType  ServiceType
  status       BookingStatus @default(pending)

  // Timing
  requestedStart DateTime
  requestedEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?

  // Location
  serviceLocationType ServiceLocationType
  serviceLat          Decimal?             @db.Decimal(10, 8)
  serviceLng          Decimal?             @db.Decimal(11, 8)
  serviceAddress      String?

  // Pricing
  basePrice        Decimal @db.Decimal(10, 2)
  commissionRate   Decimal @default(15.00) @db.Decimal(5, 2)
  commissionAmount Decimal @db.Decimal(10, 2)
  totalPrice       Decimal @db.Decimal(10, 2)
  sitterPayout     Decimal @db.Decimal(10, 2)
  currency         String  @default("EGP")

  // Payment
  paymentStatus       PaymentStatus  @default(pending)
  paymentMethod       PaymentMethod?
  paymentReference    String?
  paymentAuthorizedAt DateTime?
  paymentCapturedAt   DateTime?
  paymentRefundedAt   DateTime?
  refundAmount        Decimal?       @db.Decimal(10, 2)
  refundReason        String?

  // Cancellation
  cancelledById     String?
  cancelledBy       User?            @relation("CancelledBy", fields: [cancelledById], references: [id])
  cancelledAt       DateTime?
  cancellationReason String?
  cancellationType  CancellationType?

  // Instructions
  specialInstructions String?
  ownerNotes          String?

  // Pet snapshot (frozen at booking time)
  petSnapshot Json? // Array of pet summaries

  // Review
  ownerReviewed  Boolean  @default(false)
  sitterReviewed Boolean  @default(false)
  reviewDeadline DateTime?

  // Routing
  routingAttempt Int    @default(1)
  routingHistory Json   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  pets              BookingPet[]
  extensions        BookingExtension[]
  dispute           BookingDispute?
  tasks             BookingTask[]
  walkSessions      WalkSession[]
  reviews           Review[]
  transactions      PaymentTransaction[]
  payouts           SitterPayout[]

  @@index([ownerId, status, createdAt(sort: Desc)])
  @@index([sitterId, status, createdAt(sort: Desc)])
  @@index([status, requestedStart])
  @@map("bookings")
}

model BookingPet {
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  petId     String
  pet       Pet     @relation(fields: [petId], references: [id])

  @@id([bookingId, petId])
  @@map("booking_pets")
}

model BookingExtension {
  id              String          @id @default(uuid())
  bookingId       String
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requestedById   String
  newEndTime      DateTime
  additionalPrice Decimal?        @db.Decimal(10, 2)
  reason          String?
  status          ExtensionStatus @default(pending)
  respondedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@index([bookingId])
  @@map("booking_extensions")
}

model BookingDispute {
  id             String            @id @default(uuid())
  bookingId      String            @unique
  booking        Booking           @relation(fields: [bookingId], references: [id])
  openedById     String
  reasonCategory DisputeCategory
  description    String
  evidenceUrls   String[]
  status         DisputeStatus     @default(open)
  resolution     DisputeResolution?
  resolutionNotes String?
  resolvedById   String?
  resolvedAt     DateTime?
  appealDeadline DateTime?
  ownerAmount    Decimal?          @db.Decimal(10, 2)
  sitterAmount   Decimal?          @db.Decimal(10, 2)
  createdAt      DateTime          @default(now())

  @@index([status, createdAt])
  @@map("booking_disputes")
}

// ============================================================
// CARE TASKS & WALK TRACKING
// ============================================================

model BookingTask {
  id          String     @id @default(uuid())
  bookingId   String
  booking     Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  petId       String?
  pet         Pet?       @relation(fields: [petId], references: [id])
  taskType    TaskType
  taskName    String
  scheduledAt DateTime
  dueBy       DateTime
  completedAt DateTime?
  completedById String?
  photoUrl    String?
  notes       String?
  status      TaskStatus @default(pending)
  alertSentOwner Boolean @default(false)
  createdAt   DateTime   @default(now())

  walkSession WalkSession?

  @@index([bookingId, status, scheduledAt])
  @@index([scheduledAt, status]) // For reminder cron
  @@map("booking_tasks")
}

model WalkSession {
  id            String      @id @default(uuid())
  taskId        String      @unique
  task          BookingTask @relation(fields: [taskId], references: [id])
  bookingId     String
  booking       Booking     @relation(fields: [bookingId], references: [id])
  petIds        String[]
  sitterId      String
  startTime     DateTime
  endTime       DateTime?
  totalDistanceM Int        @default(0)
  durationSeconds Int       @default(0)
  avgSpeedKmh   Decimal?   @db.Decimal(5, 2)
  routeGeoJson  Json?      // GeoJSON LineString
  isComplete    Boolean    @default(false)
  isFraudFlagged Boolean   @default(false)
  fraudReason   String?
  createdAt     DateTime   @default(now())

  trackingPoints WalkTrackingPoint[]

  @@index([bookingId])
  @@map("walk_sessions")
}

model WalkTrackingPoint {
  id           String      @id @default(uuid())
  sessionId    String
  session      WalkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lat          Decimal     @db.Decimal(10, 8)
  lng          Decimal     @db.Decimal(11, 8)
  accuracyM    Decimal?    @db.Decimal(7, 2)
  speedMs      Decimal?    @db.Decimal(5, 2)
  altitudeM    Decimal?    @db.Decimal(8, 2)
  recordedAt   DateTime
  createdAt    DateTime    @default(now())

  @@index([sessionId, recordedAt])
  @@map("walk_tracking_points")
}

// ============================================================
// PAYMENTS
// ============================================================

model PaymentTransaction {
  id              String               @id @default(uuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id])
  bookingId       String?
  booking         Booking?             @relation(fields: [bookingId], references: [id])
  type            TransactionType
  amount          Decimal              @db.Decimal(10, 2)
  currency        String               @default("EGP")
  direction       TransactionDirection
  status          TransactionStatus    @default(pending)
  gateway         PaymentGateway?
  gatewayRef      String?
  gatewayResponse Json?
  errorMessage    String?
  retryCount      Int                  @default(0)
  processedAt     DateTime?
  createdAt       DateTime             @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([bookingId])
  @@map("payment_transactions")
}

model SitterPayout {
  id           String       @id @default(uuid())
  sitterId     String
  sitter       User         @relation(fields: [sitterId], references: [id])
  bookingId    String?
  booking      Booking?     @relation(fields: [bookingId], references: [id])
  amount       Decimal      @db.Decimal(10, 2)
  payoutMethod PayoutMethod
  destination  String?      // phone or account number (encrypted)
  status       PayoutStatus @default(pending)
  gatewayRef   String?
  scheduledAt  DateTime?
  processedAt  DateTime?
  failureReason String?
  createdAt    DateTime     @default(now())

  @@index([sitterId, status])
  @@map("sitter_payouts")
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id          String      @id @default(uuid())
  bookingId   String
  booking     Booking     @relation(fields: [bookingId], references: [id])
  reviewerId  String
  reviewer    User        @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId  String
  reviewee    User        @relation("Reviewee", fields: [revieweeId], references: [id])
  revieweeType RevieweeType

  overallRating        Decimal @db.Decimal(3, 2)

  // Owner reviewing sitter
  ratingCommunication  Decimal? @db.Decimal(3, 2)
  ratingReliability    Decimal? @db.Decimal(3, 2)
  ratingCareQuality    Decimal? @db.Decimal(3, 2)
  ratingValue          Decimal? @db.Decimal(3, 2)

  // Sitter reviewing owner
  ratingPetBehavior    Decimal? @db.Decimal(3, 2)
  ratingCleanliness    Decimal? @db.Decimal(3, 2)

  comment      String
  wouldRebook  Boolean?
  photos       String[]

  isPublished  Boolean  @default(false)
  isReported   Boolean  @default(false)
  isModerated  Boolean  @default(false)
  moderationAction ModerationAction?
  moderationNote   String?

  submittedAt DateTime @default(now())
  publishedAt DateTime?

  @@index([revieweeId, revieweeType, isPublished])
  @@index([bookingId])
  @@map("reviews")
}

model PetReview {
  id                          String   @id @default(uuid())
  bookingId                   String
  sitterId                    String
  petId                       String
  pet                         Pet      @relation(fields: [petId], references: [id])
  behaviorRating              Int
  behaviorNotes               String?
  isVisibleToFutureSitters    Boolean  @default(true)
  createdAt                   DateTime @default(now())

  @@index([petId])
  @@map("pet_reviews")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  body        String
  data        Json     @default("{}")
  isRead      Boolean  @default(false)
  isPushSent  Boolean  @default(false)
  isSmsSent   Boolean  @default(false)
  createdAt   DateTime @default(now())
  readAt      DateTime?

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================================
// SOCIAL
// ============================================================

model Follow {
  followerId String
  follower   User   @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followeeId String
  followee   User   @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([followerId, followeeId])
  @@map("follows")
}

model Playdate {
  id           String   @id @default(uuid())
  organizerId  String
  title        String
  description  String?
  locationName String?
  locationLat  Decimal? @db.Decimal(10, 8)
  locationLng  Decimal? @db.Decimal(11, 8)
  scheduledAt  DateTime
  durationMin  Int?
  maxAttendees Int?
  isPublic     Boolean  @default(true)
  petTypes     String[]
  status       String   @default("open")
  createdAt    DateTime @default(now())

  attendees PlaydateAttendee[]

  @@index([scheduledAt])
  @@map("playdates")
}

model PlaydateAttendee {
  playdateId  String
  playdate    Playdate @relation(fields: [playdateId], references: [id], onDelete: Cascade)
  userId      String
  petIds      String[]
  status      String   @default("pending")
  respondedAt DateTime?
  createdAt   DateTime @default(now())

  @@id([playdateId, userId])
  @@map("playdate_attendees")
}

// ============================================================
// PLACES
// ============================================================

model Place {
  id           String        @id @default(uuid())
  name         String
  category     PlaceCategory
  address      String?
  city         String?
  district     String?
  lat          Decimal       @db.Decimal(10, 8)
  lng          Decimal       @db.Decimal(11, 8)
  phone        String?
  website      String?
  openingHours Json?
  petPolicy    String?
  petTypesAllowed String[]
  photos       String[]
  submittedById String?
  isApproved   Boolean       @default(false)
  approvedById String?
  avgRating    Decimal       @default(0.00) @db.Decimal(3, 2)
  totalReviews Int           @default(0)
  createdAt    DateTime      @default(now())

  reviews PlaceReview[]

  @@index([lat, lng])
  @@index([category, isApproved])
  @@map("places")
}

model PlaceReview {
  id        String   @id @default(uuid())
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    String
  rating    Int
  comment   String?
  photos    String[]
  visitDate DateTime? @db.Date
  createdAt DateTime @default(now())

  @@unique([placeId, userId])
  @@index([placeId])
  @@map("place_reviews")
}

// ============================================================
// LOYALTY
// ============================================================

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  points      Int      // positive = earn, negative = redeem
  referenceId String?
  description String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@map("loyalty_transactions")
}

// ============================================================
// ADMIN
// ============================================================

model AdminAction {
  id          String   @id @default(uuid())
  adminId     String
  admin       User     @relation("AdminActor", fields: [adminId], references: [id])
  actionType  String
  targetType  String
  targetId    String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([adminId, createdAt(sort: Desc)])
  @@map("admin_actions")
}
