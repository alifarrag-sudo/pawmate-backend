// ============================================================
// USERS
// ============================================================

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  firstName    String
  lastName     String
  displayName  String?
  profilePhoto String?
  dateOfBirth  DateTime?
  gender       Gender?
  role         UserRole @default(user)

  // Dual role — "Parent" is the demand side, "PetFriend" is supply side
  isParent       Boolean    @default(true)   // was: isOwner
  isPetFriend    Boolean    @default(false)  // was: isSitter
  activeRole     ActiveRole @default(parent) // was: owner

  // Parent emergency contact
  emergencyContactName  String?
  emergencyContactPhone String?

  // Verification
  idVerified      Boolean   @default(false)
  idFrontUrl      String?
  idBackUrl       String?
  idSelfieUrl     String?
  idNumber        String?   // Encrypted Egyptian National ID
  idReviewedAt    DateTime?
  idReviewedById  String?
  idReviewer      User?     @relation("IdReviewer", fields: [idReviewedById], references: [id])
  idReviewees     User[]    @relation("IdReviewer")

  // Email + phone verification
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(true)

  // Status
  isActive      Boolean   @default(true)
  isBanned      Boolean   @default(false)
  banReason     String?
  banExpiresAt  DateTime?

  // Loyalty
  loyaltyPoints Int         @default(0)
  loyaltyTier   LoyaltyTier @default(bronze)

  // Wallet
  walletBalance      Decimal @default(0.00) @db.Decimal(10, 2)
  outstandingBalance Decimal @default(0.00) @db.Decimal(10, 2)
  currency           String  @default("EGP")

  // Preferences
  language     Language @default(ar)
  pushEnabled  Boolean  @default(true)
  smsEnabled   Boolean  @default(true)
  emailEnabled Boolean  @default(true)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  deletedAt   DateTime? // Soft delete

  // Relations
  refreshTokens         RefreshToken[]
  devices               UserDevice[]
  savedLocations        UserLocation[]
  petFriendProfile      PetFriendProfile?    // was: sitterProfile
  pets                  Pet[]
  bookingsAsParent      Booking[]            @relation("BookingParent")   // was: BookingOwner
  bookingsAsPetFriend   Booking[]            @relation("BookingPetFriend") // was: BookingSitter
  paymentTransactions   PaymentTransaction[]
  payouts               PetFriendPayout[]    // was: SitterPayout
  reviewsGiven          Review[]             @relation("Reviewer")
  reviewsReceived       Review[]             @relation("Reviewee")
  notifications         Notification[]
  followedBy            Follow[]             @relation("Followee")
  following             Follow[]             @relation("Follower")
  loyaltyTransactions   LoyaltyTransaction[]
  adminActions          AdminAction[]        @relation("AdminActor")
  cancelledBookings     Booking[]            @relation("CancelledBy")
  completedCareLogs     CareLog[]            @relation("CareLogCompleter")
  offersAsParent        Offer[]              @relation("OfferParent")    // was: OfferOwner
  offersAsPetFriend     Offer[]              @relation("OfferPetFriend") // was: OfferSitter
  providerProfile       ProviderProfile?
  providerType          ProviderType?
  products              Product[]
  ordersAsBuyer         Order[]              @relation("OrderBuyer")
  ordersAsSeller        Order[]              @relation("OrderSeller")
  foodSeller            FoodSeller?
  foodOrdersAsBuyer     FoodOrder[]          @relation("FoodOrderBuyer")
  foodReviewsGiven      FoodReview[]         @relation("FoodReviewer")
  foodReviewsReceived   FoodReview[]         @relation("FoodReviewTarget")
  waitlistEntries       UserWaitlist[]
  payoutMethods         PayoutMethodRecord[]
  trainerProfile        TrainerProfile?
  kennelProfile         KennelProfile?
  petHotelProfile       PetHotelProfile?

  // DEFERRED: Community feature
  adoptionPosts         AdoptionPost[]       @relation("AdoptionPoster")
  adoptionMessagesSent  AdoptionMessage[]    @relation("AdoptionMsgSender")
  adoptionMessagesRecv  AdoptionMessage[]    @relation("AdoptionMsgReceiver")
  causesCreated         Cause[]              @relation("CauseCreator")
  donations             Donation[]           @relation("Donor")
  withdrawalRequests    WithdrawalRequest[]  @relation("WithdrawalRequester")

  @@index([phone])
  @@index([email])
  @@index([idVerified, isActive, isBanned])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String
  deviceId    String?
  ipAddress   String?
  userAgent   String?
  isRevoked   Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model UserDevice {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken    String?
  deviceType  DeviceType
  deviceModel String?
  appVersion  String?
  osVersion   String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([fcmToken])
  @@map("user_devices")
}

model UserLocation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String   // "Home", "Work", custom
  addressLine String
  city        String?
  district    String?
  lat         Decimal  @db.Decimal(10, 8)
  lng         Decimal  @db.Decimal(11, 8)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("user_locations")
}

// ============================================================
// WAITLIST (Marketplace: Vets, Groomers, Products)
// ============================================================

model UserWaitlist {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceType WaitlistServiceType
  createdAt   DateTime            @default(now())

  @@unique([userId, serviceType])
  @@index([serviceType])
  @@map("user_waitlist")
}

// ============================================================
// PAYOUT METHODS (PetFriends, Trainers, Kennels, PetHotels)
// ============================================================

model PayoutMethodRecord {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // BANK | VODAFONE_CASH | WALLET
  details     Json     // { bankName?, accountNumber, accountHolder?, walletNumber?, provider? }
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("payout_method_records")
}

// ============================================================
// PETFRIEND PROFILES (was: SitterProfile)
// ============================================================

model PetFriendProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String?

  // Home details
  homeType         HomeType?
  hasYard          Boolean  @default(false)
  hasOtherPets     Boolean  @default(false)
  otherPetsDetails String?  // description of other pets
  hasChildren      Boolean  @default(false)
  childrenAges     String?  // e.g. "3, 7, 12"
  placePhotos      String[] @default([]) // min 3 required

  // Service pricing (set by PetFriend, in EGP)
  watchingHourlyRate  Decimal? @db.Decimal(8, 2)  // pet_watching_hourly
  watchingDailyRate   Decimal? @db.Decimal(8, 2)  // pet_watching_daily (up to 12hrs)
  overnightRate       Decimal? @db.Decimal(8, 2)  // overnight_stay per night
  walkRate30min       Decimal? @db.Decimal(8, 2)  // dog_walking 30 min
  walkRate60min       Decimal? @db.Decimal(8, 2)  // dog_walking 60 min
  overtimeRatePerHour Decimal? @db.Decimal(8, 2)  // charged after 30-min grace period

  // Availability
  maxPetsSimultaneous Int     @default(1)
  petTypesAccepted    String[] // dog, cat, both, other
  petSizesAccepted    String[] // WeightCategory values

  // Location
  lat             Decimal? @db.Decimal(10, 8)
  lng             Decimal? @db.Decimal(11, 8)
  serviceRadiusKm Int      @default(5)
  addressCity     String?
  addressDistrict String?

  // Performance metrics (updated by cron)
  avgRating        Decimal @default(0.00) @db.Decimal(3, 2)
  totalReviews     Int     @default(0)
  totalBookings    Int     @default(0)
  responseRate     Decimal @default(100.00) @db.Decimal(5, 2)
  avgResponseMin   Int     @default(0)
  reliabilityScore Decimal @default(100.00) @db.Decimal(5, 2)
  cancellationRate Decimal @default(0.00) @db.Decimal(5, 2)

  // Badges
  isVerified      Boolean @default(false)
  isFeatured      Boolean @default(false)
  instantBook     Boolean @default(false)

  // Status
  isActive       Boolean  @default(true)
  isOnHoliday    Boolean  @default(false)
  holidayEndDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  availabilityTemplates  PetFriendAvailabilityTemplate[]
  availabilityOverrides  PetFriendAvailabilityOverride[]
  certifications         PetFriendCertification[]

  @@index([lat, lng])
  @@index([isActive, isVerified])
  @@map("petfriend_profiles")
}

model PetFriendAvailabilityTemplate {
  id             String           @id @default(uuid())
  petFriendId    String
  petFriend      PetFriendProfile @relation(fields: [petFriendId], references: [id], onDelete: Cascade)
  dayOfWeek      Int              // 0=Sun, 6=Sat
  startTime      String           // "09:00"
  endTime        String           // "18:00"
  createdAt      DateTime         @default(now())

  @@index([petFriendId])
  @@map("petfriend_availability_templates")
}

model PetFriendAvailabilityOverride {
  id             String           @id @default(uuid())
  petFriendId    String
  petFriend      PetFriendProfile @relation(fields: [petFriendId], references: [id], onDelete: Cascade)
  overrideDate   DateTime         @db.Date
  isAvailable    Boolean
  startTime      String?
  endTime        String?
  reason         String?
  createdAt      DateTime         @default(now())

  @@index([petFriendId, overrideDate])
  @@map("petfriend_availability_overrides")
}

model PetFriendCertification {
  id             String           @id @default(uuid())
  petFriendId    String
  petFriend      PetFriendProfile @relation(fields: [petFriendId], references: [id], onDelete: Cascade)
  certName       String
  issuedBy       String?
  issueDate      DateTime?        @db.Date
  expiryDate     DateTime?        @db.Date
  documentUrl    String?
  isVerified     Boolean          @default(false)
  verifiedById   String?
  createdAt      DateTime         @default(now())

  @@map("petfriend_certifications")
}

// ============================================================
// TRAINER PROFILES
// ============================================================

model TrainerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  yearsExperience Int      @default(0)

  // Credentials
  certifications     Json     @default("[]") // array of { name, issuedBy, documentUrl, isVerified }
  specializations    String[] // obedience, puppy_training, behavior_modification, aggression, service_dog, agility, trick_training, other
  methodsDescription String?
  facilityPhotos     String[] @default([]) // min 3
  videoIntroUrl      String?

  // Booking lead time
  bookingLeadHours Int @default(24)

  // Performance
  avgRating    Decimal @default(0.00) @db.Decimal(3, 2)
  totalReviews Int     @default(0)

  // Location
  lat             Decimal? @db.Decimal(10, 8)
  lng             Decimal? @db.Decimal(11, 8)
  addressCity     String?
  addressDistrict String?

  // Verification
  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerings             TrainerOffering[]
  availabilityTemplates TrainerAvailabilityTemplate[]

  @@index([isActive, isVerified])
  @@map("trainer_profiles")
}

model TrainerOffering {
  id          String              @id @default(uuid())
  trainerId   String
  trainer     TrainerProfile      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  type        TrainerOfferingType
  name        String
  description String?

  // For SESSION and CONSULTATION
  durationMinutes Int?
  sessionLocation TrainerSessionLocation?
  price           Decimal?  @db.Decimal(8, 2)

  // For PACKAGE
  sessionsIncluded    Int?
  packageValidityDays Int?   // e.g. must use within 56 days (8 weeks)

  // For COURSE
  weeksCount        Int?
  sessionsPerWeek   Int?
  groupSize         TrainerGroupSize?
  curriculum        String?
  startDate         DateTime? @db.Date
  ongoingEnrollment Boolean   @default(false)

  // What's included / what parent receives
  includedDetails String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId, type, isActive])
  @@map("trainer_offerings")
}

model TrainerAvailabilityTemplate {
  id          String         @id @default(uuid())
  trainerId   String
  trainer     TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  dayOfWeek   Int            // 0=Sun, 6=Sat
  startTime   String         // "09:00"
  endTime     String         // "18:00"
  createdAt   DateTime       @default(now())

  @@index([trainerId])
  @@map("trainer_availability_templates")
}

// ============================================================
// KENNEL PROFILES
// ============================================================

model KennelProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business info
  businessName       String
  commercialRegister String? // سجل تجاري — marks as "Verified Business" if provided
  businessLicense    String? // document URL
  taxCardNumber      String?
  ownerName          String?

  // Contact
  businessPhone String?
  businessEmail String?

  // Facility
  addressLine     String?
  city            String?
  district        String?
  lat             Decimal? @db.Decimal(10, 8)
  lng             Decimal? @db.Decimal(11, 8)
  facilityPhotos  String[] @default([]) // min 5: exterior, interior, rooms, play, feeding
  totalCapacity   Int?
  operatingHours  Json?    // { mon: { open, close, closed }, ... }
  daysOpen        String[] // ["mon","tue","wed","thu","fri","sat","sun"]

  // Pet acceptance
  petTypesAccepted  String[] // dog, cat, other
  sizesAccepted     String[] // WeightCategory values

  // Amenities
  amenities         String[] // outdoor_play, indoor_play, ac, heating, cctv, grooming, vet_oncall, pool, individual_rooms, group_housing

  // Safety
  hasIsolationArea  Boolean @default(false)
  emergencyVetName  String?
  emergencyVetPhone String?

  // Pricing
  standardRatePerNight  Decimal? @db.Decimal(8, 2)
  premiumRatePerNight   Decimal? @db.Decimal(8, 2)
  daycareRatePerDay     Decimal? @db.Decimal(8, 2)
  extraServices         Json?    // [{ name, price }]
  pickupDropoffAvail    Boolean  @default(false)
  pickupDropoffPrice    Decimal? @db.Decimal(8, 2)

  // Requirements
  vaccinesRequired     String[] // list of required vaccine names
  requiresAssessment   Boolean  @default(false)
  requiresTrialDay     Boolean  @default(false)

  // Stay limits
  minStayNights Int?
  maxStayNights Int?

  // Performance
  avgRating    Decimal @default(0.00) @db.Decimal(3, 2)
  totalReviews Int     @default(0)

  // Verification
  verificationStatus VerificationStatus @default(PENDING)
  isVerified         Boolean            @default(false)
  verifiedAt         DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, isActive, isVerified])
  @@index([lat, lng])
  @@map("kennel_profiles")
}

// ============================================================
// PETHOTEL PROFILES (extends Kennel with room types)
// ============================================================

model PetHotelProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business info (same as Kennel)
  businessName       String
  commercialRegister String?
  businessLicense    String?
  taxCardNumber      String?
  ownerName          String?

  businessPhone String?
  businessEmail String?

  // Facility
  addressLine    String?
  city           String?
  district       String?
  lat            Decimal? @db.Decimal(10, 8)
  lng            Decimal? @db.Decimal(11, 8)
  facilityPhotos String[] @default([]) // min 5

  totalCapacity  Int?
  operatingHours Json?
  daysOpen       String[]

  petTypesAccepted String[]
  sizesAccepted    String[]

  // Room types: JSON array of { name, description, photos[], capacity, pricePerNight, amenities[] }
  roomTypes Json @default("[]")

  // Premium amenities (all Kennel amenities + extras)
  amenities String[] // includes: room_service, spa_grooming, webcam, daily_updates, private_play, luxury_bedding, special_diet, puppy_socialization

  hasIsolationArea  Boolean @default(false)
  emergencyVetName  String?
  emergencyVetPhone String?

  extraServices     Json?
  pickupDropoffAvail Boolean @default(false)
  pickupDropoffPrice Decimal? @db.Decimal(8, 2)

  vaccinesRequired   String[]
  requiresAssessment Boolean @default(false)
  requiresTrialDay   Boolean @default(false)

  minStayNights Int?
  maxStayNights Int?

  avgRating    Decimal @default(0.00) @db.Decimal(3, 2)
  totalReviews Int     @default(0)

  verificationStatus VerificationStatus @default(PENDING)
  isVerified         Boolean            @default(false)
  verifiedAt         DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, isActive, isVerified])
  @@index([lat, lng])
  @@map("pethotel_profiles")
}

// ============================================================
// PETS
// ============================================================

model Pet {
  id            String         @id @default(uuid())
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  species       Species
  breed         String?
  nickname      String?
  ageCategory   AgeCategory?
  neuteredStatus NeuteredStatus @default(unknown)
  houseTrained  HouseTrainedStatus @default(yes)
  color         String?
  dateOfBirth   DateTime?      @db.Date
  weightKg      Decimal?       @db.Decimal(5, 2)
  weightCategory WeightCategory?
  gender        PetGender      @default(unknown)
  isNeutered    Boolean        @default(false)

  // Microchip
  hasMicrochip  Boolean  @default(false)
  microchipId   String?

  // Photos — min 2, max 6 required by UI
  profilePhoto  String?
  photos        String[]

  // Vaccination certificate
  vaccinationCertPhoto String?   // uploaded document/photo URL
  vaccinationVerified  Boolean   @default(false) // set by admin after review

  // Special needs
  medicalConditions String? // free text
  specialNotes      String? // free text

  // Feeding schedule: JSON array of { time: "08:00", notes?: string }
  feedingSchedule Json @default("[]")

  // Walking schedule: JSON array of { time: "07:00", durationMinutes?: number }
  walkingSchedule Json @default("[]")

  // Temperament (JSON)
  temperament Json @default("{}") // { goodWithDogs, goodWithCats, goodWithChildren, isAnxious, aggressiveTendencies, notes }

  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  medicalInfo   PetMedicalInfo?
  vaccinations  PetVaccination[]
  medications   PetMedication[]
  behavior      PetBehavior?
  schedules     PetSchedule[]
  bookingPets   BookingPet[]
  petReviews    PetReview[]
  bookingTasks  BookingTask[]
  careLogs      CareLog[]

  @@index([ownerId])
  @@map("pets")
}

model PetMedicalInfo {
