// ============================================================
// PETS
// ============================================================

model Pet {
  id             String             @id @default(uuid())
  ownerId        String
  owner          User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name           String
  species        Species
  breed          String?
  nickname       String?
  ageCategory    AgeCategory?
  neuteredStatus NeuteredStatus     @default(unknown)
  houseTrained   HouseTrainedStatus @default(yes)
  color          String?
  dateOfBirth    DateTime?          @db.Date
  weightKg       Decimal?           @db.Decimal(5, 2)
  weightCategory WeightCategory?
  gender         PetGender          @default(unknown)
  isNeutered     Boolean            @default(false)

  // Microchip
  hasMicrochip Boolean @default(false)
  microchipId  String?

  // Photos — min 2, max 6 required by UI
  profilePhoto String?
  photos       String[]

  // Vaccination certificate
  vaccinationCertPhoto String? // uploaded document/photo URL
  vaccinationVerified  Boolean @default(false) // set by admin after review

  // Special needs
  medicalConditions String? // free text
  specialNotes      String? // free text

  // Feeding schedule: JSON array of { time: "08:00", notes?: string }
  feedingSchedule Json @default("[]")

  // Walking schedule: JSON array of { time: "07:00", durationMinutes?: number }
  walkingSchedule Json @default("[]")

  // Temperament (JSON)
  temperament Json @default("{}") // { goodWithDogs, goodWithCats, goodWithChildren, isAnxious, aggressiveTendencies, notes }

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  medicalInfo             PetMedicalInfo?
  vaccinations            PetVaccination[]
  medications             PetMedication[]
  behavior                PetBehavior?
  schedules               PetSchedule[]
  bookingPets             BookingPet[]
  petReviews              PetReview[]
  bookingTasks            BookingTask[]
  careLogs                CareLog[]
  vetConsultations        VetConsultation[]
  groomingAllergyNotes    String?               @db.Text
  groomingProductsToAvoid String[]              @default([])
  lastGroomedAt           DateTime?
  groomingAppointments    GroomingAppointment[]

  @@index([ownerId])
  @@map("pets")
}

model PetMedicalInfo {
  id                    String   @id @default(uuid())
  petId                 String   @unique
  pet                   Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  allergies             String[]
  medicalNotes          String?
  vetName               String?
  vetClinic             String?
  vetPhone              String?
  vetAddress            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRel   String?
  altVetName            String?
  altVetPhone           String?
  updatedAt             DateTime @updatedAt

  @@map("pet_medical_info")
}

model PetVaccination {
  id               String    @id @default(uuid())
  petId            String
  pet              Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  vaccineName      String
  administeredDate DateTime  @db.Date
  expiryDate       DateTime? @db.Date
  documentUrl      String?
  notes            String?
  createdById      String?
  createdAt        DateTime  @default(now())

  @@index([petId])
  @@index([expiryDate])
  @@map("pet_vaccinations")
}

model PetMedication {
  id             String              @id @default(uuid())
  petId          String
  pet            Pet                 @relation(fields: [petId], references: [id], onDelete: Cascade)
  name           String
  medicationType MedicationType      @default(pill)
  dosage         String?
  unit           String?
  frequency      MedicationFrequency
  adminTimes     String[] // ["08:00", "20:00"]
  startDate      DateTime?           @db.Date
  endDate        DateTime?           @db.Date
  notes          String?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())

  @@index([petId, isActive])
  @@map("pet_medications")
}

model PetBehavior {
  id              String                @id @default(uuid())
  petId           String                @unique
  pet             Pet                   @relation(fields: [petId], references: [id], onDelete: Cascade)
  temperamentTags String[]
  goodWithDogs    BehaviorCompatibility @default(yes)
  goodWithCats    BehaviorCompatibility @default(yes)
  goodWithKids    BehaviorCompatibility @default(yes)
  trainingLevel   TrainingLevel         @default(none)
  energyLevel     EnergyLevel           @default(medium)
  behaviorNotes   String?
  fearTriggers    String[]
  updatedAt       DateTime              @updatedAt

  @@map("pet_behavior")
}

model PetSchedule {
  id              String       @id @default(uuid())
  petId           String
  pet             Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  scheduleType    ScheduleType
  scheduledTime   String // "08:00"
  durationMinutes Int?
  foodType        String?
  foodAmount      String?
  notes           String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([petId, isActive])
  @@map("pet_schedules")
}

model CareLog {
  id            String         @id @default(uuid())
  bookingId     String
  booking       Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  petId         String
  pet           Pet            @relation(fields: [petId], references: [id])
  actionType    CareActionType
  scheduledTime DateTime
  completedAt   DateTime?
  completedById String?
  completedBy   User?          @relation("CareLogCompleter", fields: [completedById], references: [id])
  notes         String?
  createdAt     DateTime       @default(now())

  @@index([bookingId])
  @@index([petId])
  @@map("care_logs")
}

// ============================================================
// BOOKINGS
// ============================================================

model Booking {
  id          String  @id @default(uuid())
  parentId    String // was: ownerId
  parent      User    @relation("BookingParent", fields: [parentId], references: [id])
  petFriendId String? // null for Kennel/Trainer/PetHotel
  petFriend   User?   @relation("BookingPetFriend", fields: [petFriendId], references: [id])

  // Provider references (only one will be set based on serviceType)
  trainerProfileId String?
  trainerProfile   TrainerProfile? @relation("TrainerBookings", fields: [trainerProfileId], references: [id])
  trainerId        String?
  kennelId         String?
  petHotelId       String?

  // Trainer session/program tracking
  sessionPackageId  String? // for multi-session bookings
  sessionsCompleted Int     @default(0)
  sessionsTotal     Int? // for packages/programs
  trainerNotes      Json? // [{sessionNum, date, notes, homework}]

  bookingType     BookingType
  serviceType     ServiceType
  serviceCategory ServiceCategory? // populated alongside serviceType for new bookings
  status          BookingStatus    @default(pending)

  // Timing
  requestedStart DateTime
  requestedEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?

  // BOARDING-specific
  checkoutDate DateTime? // by 2pm on this date for boarding stays

  // DAY_CARE-specific
  sessionType    DayCareSessionType? // SIX_HOUR | EIGHT_HOUR
  sessionEndTime DateTime? // calculated on booking creation

  // Late pickup tracking (BOARDING + DAY_CARE share the same fields)
  actualPickupTime DateTime? // when parent picked up (post-stay/session)
  lateFeeEgp       Int       @default(0) // calculated and charged after pickup
  lateFeeHours     Int       @default(0) // ceiling of hours late

  // Location
  serviceLocationType ServiceLocationType
  serviceLat          Decimal?            @db.Decimal(10, 8)
  serviceLng          Decimal?            @db.Decimal(11, 8)
  serviceAddress      String?

  // Pricing
  basePrice        Decimal @db.Decimal(10, 2)
  commissionRate   Decimal @default(15.00) @db.Decimal(5, 2)
  commissionAmount Decimal @db.Decimal(10, 2)
  totalPrice       Decimal @db.Decimal(10, 2)
  providerPayout   Decimal @db.Decimal(10, 2) // was: sitterPayout
  currency         String  @default("EGP")

  // Overtime (PetFriend bookings)
  overtimeMinutes Int     @default(0)
  overtimeCharge  Decimal @default(0) @db.Decimal(8, 2)

  // Payment
  paymentStatus       PaymentStatus  @default(pending)
  paymentMethod       PaymentMethod?
  paymentReference    String?
  paymentAuthorizedAt DateTime?
  paymentCapturedAt   DateTime?
  paymentRefundedAt   DateTime?
  refundAmount        Decimal?       @db.Decimal(10, 2)
  refundReason        String?

  // Cancellation
  cancelledById      String?
  cancelledBy        User?             @relation("CancelledBy", fields: [cancelledById], references: [id])
  cancelledAt        DateTime?
  cancellationReason String?
  cancellationType   CancellationType?

  // Pickup
  readyForPickupAt  DateTime?
  pickupConfirmedAt DateTime?

  // Instructions
  specialInstructions String?
  parentNotes         String? // was: ownerNotes

  // Pet snapshot (frozen at booking time)
  petSnapshot Json? // Array of pet summaries

  // Review
  parentReviewed   Boolean   @default(false) // was: ownerReviewed
  providerReviewed Boolean   @default(false) // was: sitterReviewed
  reviewDeadline   DateTime?

  // Routing
  routingAttempt Int  @default(1)
  routingHistory Json @default("[]")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  pets                BookingPet[]
  extensions          BookingExtension[]
  dispute             BookingDispute?
  tasks               BookingTask[]
  walkSessions        WalkSession[]
  review              Review?
  transactions        PaymentTransaction[]
  payouts             PetFriendPayout[]
  careLogs            CareLog[]
  overtimeLog         OvertimeLog?
  endCode             BookingEndCode? // 4-digit service end code
  kennelStay          KennelStay? // Prompt 12: kennel boarding stay
  petHotelStay        PetHotelStay? // Prompt 13: pet hotel stay
  vetConsultation     VetConsultation? // Prompt 15: vet consultation
  groomingAppointment GroomingAppointment? // Prompt 16: grooming appointment

  @@index([parentId, status, createdAt(sort: Desc)])
  @@index([petFriendId, status, createdAt(sort: Desc)])
  @@index([status, requestedStart])
  @@index([petFriendId])
  @@index([trainerProfileId])
  @@index([paymentStatus])
  @@index([parentId, status])
  @@index([status, createdAt])
  @@index([parentId, createdAt])
  @@map("bookings")
}

