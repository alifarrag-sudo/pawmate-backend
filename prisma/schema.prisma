model FoodProduct {
  id           String           @id @default(uuid())
  sellerId     String
  seller       FoodSeller       @relation(fields: [sellerId], references: [id])
  name         String
  targetAnimal FoodTargetAnimal
  description  String
  ingredients  String[]         @default([])
  allergens    String[]         @default([])
  price        Decimal          @db.Decimal(8, 2)
  unitDesc     String
  photos       String[]         @default([])
  stock        Int              @default(0)
  isAvailable  Boolean          @default(true)
  avgRating    Decimal          @default(0.00) @db.Decimal(3, 2)
  totalReviews Int              @default(0)
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  orderItems FoodOrderItem[]
  reviews    FoodReview[]    @relation("FoodProductReviewed")

  @@index([sellerId, isAvailable])
  @@map("food_products")
}

model FoodOrder {
  id            String          @id @default(uuid())
  buyerId       String
  buyer         User            @relation("FoodOrderBuyer", fields: [buyerId], references: [id])
  sellerId      String
  seller        FoodSeller      @relation("FoodSellerOrders", fields: [sellerId], references: [id])
  status        FoodOrderStatus @default(placed)
  totalAmount   Decimal         @db.Decimal(10, 2)
  sellerEarning Decimal         @db.Decimal(10, 2)
  platformFee   Decimal         @db.Decimal(10, 2)
  pickupSlot    String
  rejectReason  String?
  buyerNote     String?
  confirmedAt   DateTime?
  readyAt       DateTime?
  pickedUpAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  items   FoodOrderItem[]
  reviews FoodReview[]    @relation("FoodOrderReviews")

  @@index([buyerId])
  @@index([buyerId, status, createdAt(sort: Desc)])
  @@index([sellerId, status, createdAt(sort: Desc)])
  @@map("food_orders")
}

model FoodOrderItem {
  id        String      @id @default(uuid())
  orderId   String
  order     FoodOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   FoodProduct @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal     @db.Decimal(8, 2)
  subtotal  Decimal     @db.Decimal(10, 2)

  @@map("food_order_items")
}

model FoodReview {
  id           String       @id @default(uuid())
  orderId      String
  order        FoodOrder    @relation("FoodOrderReviews", fields: [orderId], references: [id])
  reviewerId   String
  reviewer     User         @relation("FoodReviewer", fields: [reviewerId], references: [id])
  targetType   String // 'product' | 'seller' | 'buyer'
  productId    String?
  product      FoodProduct? @relation("FoodProductReviewed", fields: [productId], references: [id])
  sellerId     String?
  seller       FoodSeller?  @relation("FoodSellerReviewed", fields: [sellerId], references: [id])
  targetUserId String?
  targetUser   User?        @relation("FoodReviewTarget", fields: [targetUserId], references: [id])
  rating       Int
  text         String?
  createdAt    DateTime     @default(now())

  @@index([productId])
  @@index([sellerId])
  @@index([orderId])
  @@map("food_reviews")
}

// ============================================================
// SHOP PROFILES + PRODUCT CATALOG (Prompt 14)
// ============================================================

model ShopProfile {
  id                String          @id @default(cuid())
  businessProfileId String          @unique
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id])

  shopName   String?
  tagline    String?
  categories ShopCategory[]

  deliveryEnabled      Boolean @default(true)
  deliveryRadiusKm     Int     @default(10)
  deliveryCostEgp      Int     @default(25)
  freeDeliveryAboveEgp Int?
  pickupEnabled        Boolean @default(true)

  status    ShopStatus @default(PENDING_DOCS)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  products ShopProduct[]
  orders   ShopOrder[]

  @@index([status])
  @@map("shop_profiles")
}

model ShopProduct {
  id            String      @id @default(cuid())
  shopProfileId String
  shopProfile   ShopProfile @relation(fields: [shopProfileId], references: [id])

  name        String
  brand       String?
  category    ShopCategory
  description String?      @db.Text

  visionExtractedJson Json?
  visionProcessedAt   DateTime?
  visionModel         String?

  weightGrams     Int?
  dimensions      String?
  targetPetType   String[] @default([])
  targetAgeGroup  String[] @default([])
  targetSizeGroup String[] @default([])

  ingredientsList String?   @db.Text
  safetyFlags     String[]  @default([])
  safetyFlaggedAt DateTime?

  priceEgp        Int
  comparePriceEgp Int?
  costEgp         Int?

  stockCount        Int     @default(0)
  lowStockThreshold Int     @default(5)
  trackInventory    Boolean @default(true)
  allowBackorder    Boolean @default(false)

  photosUrls   String[] @default([])
  thumbnailUrl String?

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems ShopOrderItem[]

  @@index([shopProfileId, category])
  @@index([shopProfileId, isActive])
  @@index([safetyFlags])
  @@map("shop_products")
}

model ShopOrder {
  id            String      @id @default(cuid())
  shopProfileId String
  shopProfile   ShopProfile @relation(fields: [shopProfileId], references: [id])
  parentUserId  String
  parentUser    User        @relation("ShopParentOrders", fields: [parentUserId], references: [id])

  items ShopOrderItem[]

  subtotalEgp     Int
  deliveryCostEgp Int @default(0)
  discountEgp     Int @default(0)
  totalEgp        Int
  platformFeeEgp  Int
  shopNetEgp      Int

  deliveryType    DeliveryType @default(DELIVERY)
  deliveryAddress String?      @db.Text
  deliveryLat     Float?
  deliveryLng     Float?

  status ShopOrderStatus @default(PENDING_PAYMENT)

  confirmedAt        DateTime?
  dispatchedAt       DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  paymobOrderId       String?
  paymobTransactionId String?
  paidAt              DateTime?
  refundedAt          DateTime?
  refundedAmountEgp   Int?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopProfileId, status])
  @@index([parentUserId])
  @@map("shop_orders")
}

model ShopOrderItem {
  id           String      @id @default(cuid())
  orderId      String
  order        ShopOrder   @relation(fields: [orderId], references: [id])
  productId    String
  product      ShopProduct @relation(fields: [productId], references: [id])
  quantity     Int
  unitPriceEgp Int
  totalEgp     Int

  @@index([orderId])
  @@index([productId])
  @@map("shop_order_items")
}

// ============================================================
// VET CLINIC PROFILES + MEDICAL RECORDS (Prompt 15 — PDPL encrypted)
// ============================================================

model VetProfile {
  id                String          @id @default(cuid())
  businessProfileId String          @unique
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id])

  clinicName          String?
  licenseNumber       String
  syndicateCardUrl    String?
  syndicateVerified   Boolean   @default(false)
  syndicateVerifiedAt DateTime?
  syndicateVerifiedBy String?

  specialties VetSpecialty[]

  offersInClinic     Boolean @default(true)
  offersHomeVisits   Boolean @default(false)
  homeVisitRadiusKm  Int?
  homeVisitCostEgp   Int?
  offersVideoConsult Boolean @default(false)

  offersEmergency       Boolean @default(false)
  emergencyPhone        String?
  emergencyAvailability String?

  consultationFeeEgp Int
  homeVisitFeeEgp    Int?
  videoConsultFeeEgp Int?

  affiliations VetAffiliation[]

  dataRetentionYears Int     @default(7)
  consentVersion     Int     @default(1)
  consentText        String? @db.Text

  status    VetStatus @default(PENDING_DOCS)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  consultations VetConsultation[]

  @@index([status])
  @@map("vet_profiles")
}

model VetAffiliation {
  id           String     @id @default(cuid())
  vetProfileId String
  vetProfile   VetProfile @relation(fields: [vetProfileId], references: [id])

  institutionName String
  role            String?
  licenseOrId     String?
  documentUrl     String?

  verificationStatus AffiliationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedBy         String?
  rejectionReason    String?

  createdAt DateTime @default(now())

  @@index([vetProfileId])
  @@index([verificationStatus])
  @@map("vet_affiliations")
}

model VetConsultation {
  id           String     @id @default(cuid())
  vetProfileId String
  vetProfile   VetProfile @relation(fields: [vetProfileId], references: [id])
  petId        String
  pet          Pet        @relation(fields: [petId], references: [id])
  bookingId    String?    @unique
  booking      Booking?   @relation(fields: [bookingId], references: [id])

  consultationType ConsultationType
  consultedAt      DateTime

  chiefComplaintEnc String? @db.Text
  findingsEnc       String? @db.Text
  diagnosisEnc      String? @db.Text
  treatmentPlanEnc  String? @db.Text
  notesEnc          String? @db.Text

  encryptionVersion Int     @default(1)
  encryptionKeyId   String?

  weight           Decimal?  @db.Decimal(5, 2)
  temperature      Decimal?  @db.Decimal(4, 1)
  heartRate        Int?
  followUpDate     DateTime?
  followUpRequired Boolean   @default(false)

  attachmentsJson Json?

  parentConsentGiven Boolean   @default(false)
  parentConsentAt    DateTime?
  consentVersion     Int?

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  prescriptions EPrescription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vetProfileId])
  @@index([petId])
  @@map("vet_consultations")
}

model EPrescription {
  id             String          @id @default(cuid())
  consultationId String
  consultation   VetConsultation @relation(fields: [consultationId], references: [id])

  prescriptionNumber String   @unique
  issuedAt           DateTime @default(now())
  expiresAt          DateTime

  medicationsEnc  String  @db.Text
  instructionsEnc String? @db.Text

  encryptionVersion Int @default(1)

  contentHash   String
  hashAlgorithm String @default("SHA-256")

  status      PrescriptionStatus @default(ACTIVE)
  dispensedAt DateTime?
  dispensedBy String?

  parentViewedAt DateTime?

  createdAt DateTime @default(now())

  @@index([consultationId])
  @@index([prescriptionNumber])
  @@map("e_prescriptions")
}

// ============================================================
// GROOMER PROFILES + APPOINTMENTS (Prompt 16 — final provider type)
// ============================================================

model GroomerProfile {
  id                String          @id @default(cuid())
  businessProfileId String          @unique
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id])

  hasSalon          Boolean @default(true)
  salonAddress      String?
  salonLat          Float?
  salonLng          Float?
  hasMobileVan      Boolean @default(false)
  mobileVanRadiusKm Int?
  mobileVanCostEgp  Int?
  freeVanAboveEgp   Int?

  experienceYears Int?
  bio             String? @db.Text

  acceptsDogs  Boolean @default(true)
  acceptsCats  Boolean @default(false)
  acceptsOther Boolean @default(false)

  slotDurationMinutes     Int     @default(60)
  advanceBookingDays      Int     @default(30)
  sameHourBooking         Boolean @default(false)
  cancellationWindowHours Int     @default(24)

  portfolioPhotosUrls String[] @default([])

  status    GroomerStatus @default(PENDING_DOCS)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  services     GroomerService[]
  appointments GroomingAppointment[]

  @@index([status])
  @@index([hasMobileVan])
  @@map("groomer_profiles")
}

model GroomerService {
  id               String         @id @default(cuid())
  groomerProfileId String
  groomerProfile   GroomerProfile @relation(fields: [groomerProfileId], references: [id])

  serviceType     GroomingServiceType
  name            String
  description     String?
  durationMinutes Int

  priceSmallEgp  Int?
  priceMediumEgp Int?
  priceLargeEgp  Int?
  priceXLEgp     Int?
  priceFlat      Int?

  mobileVanSurchargeEgp Int?

  isActive  Boolean @default(true)
  isPopular Boolean @default(false)

  appointments GroomingAppointment[]

  @@index([groomerProfileId])
  @@map("groomer_services")
}

model GroomingAppointment {
  id               String         @id @default(cuid())
  bookingId        String         @unique
  booking          Booking        @relation(fields: [bookingId], references: [id])
  groomerProfileId String
  groomerProfile   GroomerProfile @relation(fields: [groomerProfileId], references: [id])
  serviceId        String
  service          GroomerService @relation(fields: [serviceId], references: [id])
  petId            String
  pet              Pet            @relation(fields: [petId], references: [id])

  mode                 GroomingMode @default(IN_SALON)
  appointmentAt        DateTime
  estimatedDurationMin Int
  actualDurationMin    Int?

  clientAddress      String? @db.Text
  clientLat          Float?
  clientLng          Float?
  travelSurchargeEgp Int     @default(0)

  allergyNotes        String? @db.Text
  specialInstructions String? @db.Text

  beforePhotosUrls String[] @default([])
  afterPhotosUrls  String[] @default([])

  groomingNotes     String?  @db.Text
  reactionsObserved String[] @default([])

  sharedByParent      Boolean   @default(false)
  shareToken          String?   @unique
  shareTokenExpiresAt DateTime?

  status AppointmentStatus @default(CONFIRMED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groomerProfileId, status])
  @@index([appointmentAt])
  @@index([petId])
  @@map("grooming_appointments")
}

// ── Event Bridge Delivery Tracking ──────────────────────────────────────────

model EventBridgeDelivery {
  id            String    @id @default(cuid())
  eventId       String    @unique
  eventName     String
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  lastError     String?
  delivered     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([delivered, createdAt])
  @@index([eventName])
  @@map("event_bridge_deliveries")
}

// ============================================================
// OPERATOR / BUSINESS PROFILES (Prompt 10)
// ============================================================

model BusinessProfile {
  id      String @id @default(cuid())
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id])

  // Identity
  businessName  String
  businessType  BusinessType
  description   String?      @db.Text
  logoUrl       String?
  coverPhotoUrl String?
  photosUrls    String[]     @default([])

  // Legal
  commercialRegNumber String?
  taxCard             String? // Cloudinary URL for tax card doc
  commercialRegDocUrl String?

  // Contact
  businessEmail  String
  businessPhone  String
  whatsappNumber String?
  websiteUrl     String?

  // Location
  primaryAddress String
  primaryCity    String
  primaryLat     Float?
  primaryLng     Float?
  branches       BusinessBranch[]

  // Services offered (roll-up of team)
  servicesJson Json? // aggregated view of what team can do

  // Tier (team size limits)
  businessTier String @default("FREE") // "FREE" or "PREMIUM"

  // Status
  status          BusinessStatus @default(PENDING_DOCS)
  appliedAt       DateTime       @default(now())
  autoApprovedAt  DateTime?
  adminReviewedAt DateTime?

  // Reputation (aggregated from team)
  totalBookings Int    @default(0)
  averageRating Float?

  // Team
  teamMembers TeamMember[]
  invites     TeamInvite[]

  // Kennel-specific profile (Prompt 12)
  kennelProfile KennelProfile?

  // PetHotel-specific profile (Prompt 13)
  petHotelProfile PetHotelProfile?

  // Shop-specific profile (Prompt 14)
  shopProfile ShopProfile?

  // Vet clinic profile (Prompt 15)
  vetProfile VetProfile?

  // Groomer profile (Prompt 16)
  groomerProfile GroomerProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primaryCity])
  @@index([status])
  @@index([businessType])
  @@map("business_profiles")
}

model BusinessBranch {
  id         String          @id @default(cuid())
  businessId String
  business   BusinessProfile @relation(fields: [businessId], references: [id])
  name       String
  address    String
  city       String
  lat        Float?
  lng        Float?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())

  @@index([businessId])
  @@map("business_branches")
}

model TeamMember {
  id         String          @id @default(cuid())
  businessId String
  business   BusinessProfile @relation(fields: [businessId], references: [id])
  userId     String
  user       User            @relation("TeamMemberships", fields: [userId], references: [id])

  role              TeamRole     @default(PROVIDER)
  providerType      ProviderType // PETFRIEND or TRAINER
  providerProfileId String? // links to PetFriendProfile or TrainerProfile

  // Permissions granted by operator
  canAcceptBookings     Boolean @default(true)
  canSetOwnAvailability Boolean @default(true)
  canMessageParents     Boolean @default(true)
  canWithdrawEarnings   Boolean @default(true) // if false: operator manages payouts

  // Status
  status          TeamMemberStatus @default(ACTIVE)
  joinedAt        DateTime         @default(now())
  suspendedAt     DateTime?
  suspendedReason String?
  removedAt       DateTime?

  // Assignment
  assignedBranchId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@map("team_members")
}

model TeamInvite {
  id                 String          @id @default(cuid())
  businessId         String
  business           BusinessProfile @relation(fields: [businessId], references: [id])
  inviteCode         String          @unique
  inviteLinkUrl      String? // full deep-link URL
  invitedEmail       String? // optional; if set, invite pre-fills on signup
  invitedPhone       String?
  invitedName        String?
  targetRole         TeamRole        @default(PROVIDER)
  targetProviderType ProviderType    @default(PETFRIEND)

  createdBy    String // userId of operator/manager who created
  createdAt    DateTime     @default(now())
  expiresAt    DateTime // default 7 days from creation
  usedAt       DateTime?
  usedByUserId String?
  status       InviteStatus @default(PENDING)

  @@index([inviteCode])
  @@index([businessId, status])
  @@map("team_invites")
}

// ============================================================
// REFERRALS
// ============================================================

enum ReferralStatus {
  PENDING // code shared, not yet used
  SIGNED_UP // referee signed up with code
  QUALIFIED // referee completed qualifying event
  REWARDED // referrer received reward
  EXPIRED // 90 days no action
}

model Referral {
  id                String         @id @default(cuid())
  referrerUserId    String
  referrer          User           @relation("ReferralsMade", fields: [referrerUserId], references: [id])
  referralCode      String
  refereeUserId     String?
  referee           User?          @relation("ReferralsReceived", fields: [refereeUserId], references: [id])
  refereeRole       String? // "PARENT" or "PETFRIEND"
  status            ReferralStatus @default(PENDING)
  rewardEgp         Int            @default(0)
  rewardType        String? // "CREDIT" or "CASH"
  qualifyingEventId String? // booking ID that qualified the referral
  createdAt         DateTime       @default(now())
  qualifiedAt       DateTime?
  rewardedAt        DateTime?

  @@index([referrerUserId])
  @@index([referralCode])
  @@index([refereeUserId])
  @@index([status])
  @@map("referrals")
}

// ============================================================
// WEB PLATFORM SUPPORT (PawMateHub web — Prompt 10.5)
// ============================================================

enum ContactType {
  PARENT
  PROVIDER
  BUSINESS
  PRESS
  OTHER
}

model ContactSubmission {
  id        String      @id @default(uuid())
  name      String
  email     String
  type      ContactType
  message   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([email])
  @@index([type, createdAt(sort: Desc)])
  @@map("contact_submissions")
}

model WebApplicationDraft {
  id        String   @id @default(uuid())
  userId    String?  @unique // null for guest applications
  email     String?  @unique // guest identifier when userId is null
  step      Int      @default(1)
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([email])
  @@map("web_application_drafts")
}
