// ============================================================
// REVIEWS
// ============================================================

model Review {
  id         String  @id @default(cuid())
  bookingId  String  @unique
  booking    Booking @relation(fields: [bookingId], references: [id])
  reviewerId String
  reviewer   User    @relation("Reviewer", fields: [reviewerId], references: [id])

  // Legacy fields kept for backward compat
  revieweeId   String?
  reviewee     User?         @relation("Reviewee", fields: [revieweeId], references: [id])
  revieweeType RevieweeType?

  // Provider identity (polymorphic)
  providerUserId    String?
  kennelProfileId   String?
  petHotelProfileId String?
  shopProfileId     String?
  vetProfileId      String?
  groomerProfileId  String?
  providerType      ProviderType?

  // Ratings
  rating              Int      @default(5)
  overallRating       Decimal? @db.Decimal(3, 2)
  ratingCommunication Decimal? @db.Decimal(3, 2)
  ratingReliability   Decimal? @db.Decimal(3, 2)
  ratingCareQuality   Decimal? @db.Decimal(3, 2)
  ratingValue         Decimal? @db.Decimal(3, 2)
  ratingPetBehavior   Decimal? @db.Decimal(3, 2)
  ratingCleanliness   Decimal? @db.Decimal(3, 2)

  // Content
  tags        String[] @default([])
  comment     String?  @db.Text
  wouldRebook Boolean?
  photos      String[] @default([])

  // Reply
  replyText            String?     @db.Text
  replyStatus          ReplyStatus @default(NO_REPLY)
  replyDraftText       String?     @db.Text
  replySubmittedAt     DateTime?
  replyApprovedAt      DateTime?
  replyApprovedBy      String?
  replyRejectedAt      DateTime?
  replyRejectionReason String?

  // Moderation
  isVisible        Boolean           @default(true)
  isPublished      Boolean           @default(true)
  isFlagged        Boolean           @default(false)
  flaggedAt        DateTime?
  flaggedReason    String?
  flaggedByUserId  String?
  isReported       Boolean           @default(false)
  isModerated      Boolean           @default(false)
  moderationAction ModerationAction?
  moderationNote   String?
  moderatedAt      DateTime?
  moderatedBy      String?

  // Analytics
  helpfulCount Int @default(0)

  submittedAt DateTime  @default(now())
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([providerUserId])
  @@index([kennelProfileId])
  @@index([petHotelProfileId])
  @@index([shopProfileId])
  @@index([vetProfileId])
  @@index([groomerProfileId])
  @@index([providerType, rating])
  @@index([isVisible, isFlagged])
  @@index([revieweeId, revieweeType, isPublished])
  @@index([bookingId])
  @@map("reviews")
}

model ReputationSnapshot {
