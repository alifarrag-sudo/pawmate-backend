// ============================================================
// USERS
// ============================================================

model User {
  id           String   @id @default(uuid())
  phone        String?  @unique  // optional — email-first auth; phone added later for SMS verify
  email        String   @unique  // required — DB is NOT NULL; primary identifier for auth flows
  passwordHash String?           // null for social-login users (Google/Facebook)
  firstName    String
  lastName     String
  displayName  String?
  profilePhoto String?
  dateOfBirth  DateTime?
  gender       Gender?
  role         UserRole @default(user)

  // Auth provider tracking
  authProvider   String  @default("email")  // "email" | "google" | "facebook"
  authProviderId String?                    // social provider's user ID

  // Multi-role system — array of active roles for this user
  // Values: "PARENT" | "PETFRIEND" | "TRAINER" | "KENNEL" | "PETHOTEL" | "SHOP" | "GROOMER" | "VET"
  roles          String[] @default(["PARENT"])

  // Legacy role flags — kept for backward compatibility with existing code
  isParent       Boolean    @default(true)   // was: isOwner
  isPetFriend    Boolean    @default(false)  // was: isSitter
  activeRole     ActiveRole @default(parent) // was: owner

  // Parent emergency contact
  emergencyContactName  String?
  emergencyContactPhone String?

  // Verification
  idVerified      Boolean   @default(false)
  idFrontUrl      String?
  idBackUrl       String?
  idSelfieUrl     String?
  idNumber        String?   // Encrypted Egyptian National ID
  idReviewedAt    DateTime?
  idReviewedById  String?
  idReviewer      User?     @relation("IdReviewer", fields: [idReviewedById], references: [id])
  idReviewees     User[]    @relation("IdReviewer")

  // Email + phone verification
  emailVerified   Boolean   @default(false)  // set true after email code verified or via Google/Facebook
  emailVerifiedAt DateTime?                  // timestamp of first verification
  phoneVerified   Boolean   @default(false)  // set true after SMS OTP verified

  // Status
  isActive      Boolean   @default(true)
  isBanned      Boolean   @default(false)
  banReason     String?
  banExpiresAt  DateTime?

  // Loyalty
  loyaltyPoints Int         @default(0)
  loyaltyTier   LoyaltyTier @default(bronze)

  // Wallet
  walletBalance      Decimal @default(0.00) @db.Decimal(10, 2)
  outstandingBalance Decimal @default(0.00) @db.Decimal(10, 2)
  currency           String  @default("EGP")

  // Preferences
  language     Language @default(ar)
  pushEnabled  Boolean  @default(true)
  smsEnabled   Boolean  @default(true)
  emailEnabled Boolean  @default(true)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  deletedAt   DateTime? // Soft delete

  // Relations
  refreshTokens         RefreshToken[]
  devices               UserDevice[]
  savedLocations        UserLocation[]
  petFriendProfile      PetFriendProfile?    // was: sitterProfile
  pets                  Pet[]
  bookingsAsParent      Booking[]            @relation("BookingParent")   // was: BookingOwner
  bookingsAsPetFriend   Booking[]            @relation("BookingPetFriend") // was: BookingSitter
  paymentTransactions   PaymentTransaction[]
  payouts               PetFriendPayout[]    @relation("UserPayouts") // was: SitterPayout
  reviewsGiven          Review[]             @relation("Reviewer")
  reviewsReceived       Review[]             @relation("Reviewee")
  notifications         Notification[]
  followedBy            Follow[]             @relation("Followee")
  following             Follow[]             @relation("Follower")
  loyaltyTransactions   LoyaltyTransaction[]
  adminActions          AdminAction[]        @relation("AdminActor")
  cancelledBookings     Booking[]            @relation("CancelledBy")
  completedCareLogs     CareLog[]            @relation("CareLogCompleter")
  offersAsParent        Offer[]              @relation("OfferParent")    // was: OfferOwner
  offersAsPetFriend     Offer[]              @relation("OfferPetFriend") // was: OfferSitter
  providerProfile       ProviderProfile?
  providerType          ProviderType?
  products              Product[]
  ordersAsBuyer         Order[]              @relation("OrderBuyer")
  ordersAsSeller        Order[]              @relation("OrderSeller")
  foodSeller            FoodSeller?
  foodOrdersAsBuyer     FoodOrder[]          @relation("FoodOrderBuyer")
  foodReviewsGiven      FoodReview[]         @relation("FoodReviewer")
  foodReviewsReceived   FoodReview[]         @relation("FoodReviewTarget")
  waitlistEntries       UserWaitlist[]
  payoutMethods         PayoutMethodRecord[]
  trainerProfile        TrainerProfile?
  // kennelProfile moved to BusinessProfile in Prompt 12
  petHotelProfile       PetHotelProfile?

  // Referral system
  referralCode        String?           @unique
  accountCreditEgp    Int               @default(0)
  referralsMade       Referral[]        @relation("ReferralsMade")
  referralsReceived   Referral[]        @relation("ReferralsReceived")

  // Operator / Business (Prompt 10)
  businessProfile     BusinessProfile?
  teamMemberships     TeamMember[]      @relation("TeamMemberships")

  // DEFERRED: Community feature
  adoptionPosts         AdoptionPost[]       @relation("AdoptionPoster")
  adoptionMessagesSent  AdoptionMessage[]    @relation("AdoptionMsgSender")
  adoptionMessagesRecv  AdoptionMessage[]    @relation("AdoptionMsgReceiver")
  causesCreated         Cause[]              @relation("CauseCreator")
  donations             Donation[]           @relation("Donor")
  withdrawalRequests    WithdrawalRequest[]  @relation("WithdrawalRequester")

  @@index([phone])
  @@index([email])
  @@index([idVerified, isActive, isBanned])
  @@index([authProvider, authProviderId])
  @@index([emailVerified])
  @@index([referralCode])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String
  deviceId    String?
  ipAddress   String?
  userAgent   String?
  isRevoked   Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model UserDevice {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken    String?
  deviceType  DeviceType
  deviceModel String?
  appVersion  String?
  osVersion   String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([fcmToken])
  @@map("user_devices")
}

model UserLocation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String   // "Home", "Work", custom
  addressLine String
  city        String?
  district    String?
  lat         Decimal  @db.Decimal(10, 8)
  lng         Decimal  @db.Decimal(11, 8)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("user_locations")
}

// ============================================================
// WAITLIST (Marketplace: Vets, Groomers, Products)
// ============================================================

model UserWaitlist {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceType WaitlistServiceType
  createdAt   DateTime            @default(now())

  @@unique([userId, serviceType])
  @@index([serviceType])
  @@map("user_waitlist")
}

// ============================================================
// PAYOUT METHODS (PetFriends, Trainers, Kennels, PetHotels)
// ============================================================

model PayoutMethodRecord {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // BANK | VODAFONE_CASH | WALLET
  details     Json     // { bankName?, accountNumber, accountHolder?, walletNumber?, provider? }
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("payout_method_records")
}

// ============================================================
// PETFRIEND PROFILES (was: SitterProfile)
// ============================================================

model PetFriendProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String?

  // Home details
  homeType         HomeType?
  hasYard          Boolean  @default(false)
  hasOtherPets     Boolean  @default(false)
  otherPetsDetails String?  // description of other pets
  hasChildren      Boolean  @default(false)
  childrenAges     String?  // e.g. "3, 7, 12"
  placePhotos      String[] @default([]) // min 3 required

  // Service pricing (set by PetFriend, in EGP)
  watchingHourlyRate  Decimal? @db.Decimal(8, 2)  // pet_watching_hourly
  watchingDailyRate   Decimal? @db.Decimal(8, 2)  // pet_watching_daily (up to 12hrs)
  overnightRate       Decimal? @db.Decimal(8, 2)  // overnight_stay per night
  walkRate30min       Decimal? @db.Decimal(8, 2)  // dog_walking 30 min
  walkRate60min       Decimal? @db.Decimal(8, 2)  // dog_walking 60 min
  overtimeRatePerHour Decimal? @db.Decimal(8, 2)  // charged after 30-min grace period

  // Availability
  maxPetsSimultaneous Int     @default(1)
  petTypesAccepted    String[] // dog, cat, both, other
  petSizesAccepted    String[] // WeightCategory values

  // Location
  lat             Decimal? @db.Decimal(10, 8)
  lng             Decimal? @db.Decimal(11, 8)
  serviceRadiusKm Int      @default(5)
  addressCity     String?
  addressDistrict String?

  // Performance metrics (updated by cron)
  avgRating        Decimal @default(0.00) @db.Decimal(3, 2)
  totalReviews     Int     @default(0)
  totalBookings    Int     @default(0)
  responseRate     Decimal @default(100.00) @db.Decimal(5, 2)
  avgResponseMin   Int     @default(0)
  reliabilityScore Decimal @default(100.00) @db.Decimal(5, 2)
  cancellationRate Decimal @default(0.00) @db.Decimal(5, 2)

  // Badges
  isVerified      Boolean @default(false)
  isFeatured      Boolean @default(false)
  instantBook     Boolean @default(false)

  // KYC documents (Cloudinary URLs) — stored here for provider-specific docs
  pccUrl          String?   // Police Clearance Certificate
  selfieWithIdUrl String?   // Selfie holding ID

  // Service offerings
  servicesOffered      String[]  @default([])  // e.g. ["BOARDING","DAY_VISIT","WALKING","GROOMING","TRAINING"]
  acceptsDogs          Boolean   @default(true)
  acceptsCats          Boolean   @default(true)
  acceptsOther         Boolean   @default(false)
  maxPetsPerBooking    Int       @default(3)
  maxDogSizeKg         Int?

  // Simplified integer pricing (EGP) — complement to existing Decimal rates
  ratePerHour   Int?
  ratePerDay    Int?
  ratePerNight  Int?
  ratePerWalk   Int?

  // Availability JSON (weekly schedule)
  availabilityJson Json?

  // Application status workflow
  status             PetFriendStatus @default(PENDING_DOCS)
  appliedAt          DateTime        @default(now())
  autoApprovedAt     DateTime?
  adminReviewedAt    DateTime?
  adminReviewedBy    String?
  rejectionReason    String?
  suspendedUntil     DateTime?

  // Commission & reputation
  fiveStarCount   Int   @default(0)
  commissionRate  Float @default(0.15)  // 0.15 for new, 0.10 for elite (4.5★ + 20 bookings)

  // Payout wallet
  payoutMethodJson    Json?
  availableBalanceEgp Int  @default(0)
  pendingBalanceEgp   Int  @default(0)
  totalEarnedEgp      Int  @default(0)
  lastPayoutAt        DateTime?

  // Status
  isActive       Boolean  @default(true)
  isOnHoliday    Boolean  @default(false)
  holidayEndDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  availabilityTemplates  PetFriendAvailabilityTemplate[]
  availabilityOverrides  PetFriendAvailabilityOverride[]
  certifications         PetFriendCertification[]
  payouts                PetFriendPayout[] @relation("ProfilePayouts")

  @@index([lat, lng])
  @@index([isActive, isVerified])
  @@index([status])
  @@map("petfriend_profiles")
}

model PetFriendAvailabilityTemplate {
  id             String           @id @default(uuid())
  petFriendId    String
  petFriend      PetFriendProfile @relation(fields: [petFriendId], references: [id], onDelete: Cascade)
  dayOfWeek      Int              // 0=Sun, 6=Sat
  startTime      String           // "09:00"
  endTime        String           // "18:00"
  createdAt      DateTime         @default(now())

  @@index([petFriendId])
  @@map("petfriend_availability_templates")
}

model PetFriendAvailabilityOverride {
  id             String           @id @default(uuid())
  petFriendId    String
  petFriend      PetFriendProfile @relation(fields: [petFriendId], references: [id], onDelete: Cascade)
  overrideDate   DateTime         @db.Date
  isAvailable    Boolean
  startTime      String?
  endTime        String?
  reason         String?
  createdAt      DateTime         @default(now())

  @@index([petFriendId, overrideDate])
  @@map("petfriend_availability_overrides")
}

model PetFriendCertification {
  id             String           @id @default(uuid())
  petFriendId    String
  petFriend      PetFriendProfile @relation(fields: [petFriendId], references: [id], onDelete: Cascade)
  certName       String
  issuedBy       String?
  issueDate      DateTime?        @db.Date
  expiryDate     DateTime?        @db.Date
  documentUrl    String?
  isVerified     Boolean          @default(false)
  verifiedById   String?
  createdAt      DateTime         @default(now())

  @@map("petfriend_certifications")
}

// ============================================================
// TRAINER PROFILES (Prompt 9 — specialist provider)
// ============================================================

model TrainerProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  bio                   String?   @db.Text
  specialties           String[]  @default([])  // ["OBEDIENCE","BEHAVIOR_CORRECTION","PUPPY","AGGRESSION","AGILITY","SERVICE_DOG"]
  experienceYears       Int?
  languages             String[]  @default(["Arabic"])
  city                  String?

  // Documents (Cloudinary URLs)
  profilePhotoUrl       String?
  idFrontUrl            String?
  idBackUrl             String?
  certificationsJson    Json?     // [{name, issuer, year, url}] — at least one required for approval
  showcaseVideoUrl      String?   // optional intro video

  // Service delivery
  inHomeVisits          Boolean   @default(false)
  ownFacility           Boolean   @default(false)
  facilityAddress       String?
  facilityPhotosUrls    String[]  @default([])
  virtualSessions       Boolean   @default(false)
  serviceRadiusKm       Int       @default(10)  // for in-home visits
  baseLat               Float?
  baseLng               Float?

  // Services offered with pricing
  servicesJson          Json?     // [{type, priceEgp, description, deliveryMode}]

  // Availability
  availabilityJson      Json?
  maxSessionsPerDay     Int       @default(4)

  // Status
  status                TrainerStatus @default(PENDING_DOCS)
  appliedAt             DateTime  @default(now())
  autoApprovedAt        DateTime?
  adminReviewedAt       DateTime?
  adminReviewedBy       String?
  rejectionReason       String?
  suspendedUntil        DateTime?

  // Reputation
  totalSessions         Int       @default(0)
  totalPrograms         Int       @default(0)
  averageRating         Float?
  fiveStarCount         Int       @default(0)
  commissionRate        Float     @default(0.15)

  // Payout
  payoutMethodJson      Json?
  availableBalanceEgp   Int       @default(0)
  pendingBalanceEgp     Int       @default(0)
  totalEarnedEgp        Int       @default(0)
  lastPayoutAt          DateTime?

  // Performance tracking
  completionRate        Float?    // programs completed vs started

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  bookings              Booking[] @relation("TrainerBookings")
  trainerPayouts        TrainerPayout[]

  // Legacy relations kept for migration compatibility
  offerings             TrainerOffering[]
  availabilityTemplates TrainerAvailabilityTemplate[]

  @@index([status])
  @@index([city])
  @@index([averageRating])
  @@map("trainer_profiles")
}

model TrainerOffering {
  id          String              @id @default(uuid())
  trainerId   String
  trainer     TrainerProfile      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  type        TrainerOfferingType
  name        String
  description String?

  // For SESSION and CONSULTATION
  durationMinutes Int?
  sessionLocation TrainerSessionLocation?
  price           Decimal?  @db.Decimal(8, 2)

  // For PACKAGE
  sessionsIncluded    Int?
  packageValidityDays Int?   // e.g. must use within 56 days (8 weeks)

  // For COURSE
  weeksCount        Int?
  sessionsPerWeek   Int?
  groupSize         TrainerGroupSize?
  curriculum        String?
  startDate         DateTime? @db.Date
  ongoingEnrollment Boolean   @default(false)

  // What's included / what parent receives
  includedDetails String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId, type, isActive])
  @@map("trainer_offerings")
}

model TrainerAvailabilityTemplate {
  id          String         @id @default(uuid())
  trainerId   String
  trainer     TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  dayOfWeek   Int            // 0=Sun, 6=Sat
  startTime   String         // "09:00"
  endTime     String         // "18:00"
  createdAt   DateTime       @default(now())

  @@index([trainerId])
  @@map("trainer_availability_templates")
}

// ============================================================
// KENNEL PROFILES (Prompt 12 — linked to BusinessProfile)
// ============================================================

model KennelProfile {
  id                    String    @id @default(cuid())
  businessProfileId     String    @unique
  businessProfile       BusinessProfile @relation(fields: [businessProfileId], references: [id])

  // Facility
  totalUnits            Int
  facilityType          KennelFacilityType @default(STANDARD)
  acceptsCats           Boolean   @default(false)
  acceptsDogs           Boolean   @default(true)
  acceptsOtherPets      Boolean   @default(false)
  maxPetWeightKg        Int?      // per-unit weight limit

  // Services
  providesFood          Boolean   @default(false)  // else parent brings food
  providesBedding       Boolean   @default(true)
  providesPlayArea      Boolean   @default(false)
  playAreaHoursPerDay   Int?
  walksPerDay           Int       @default(2)
  photoUpdatesPerDay    Int       @default(1)
  airConditioned        Boolean   @default(true)
  heated                Boolean   @default(true)
  securityMonitored     Boolean   @default(true)

  // Operating hours for pickup/drop-off
  pickupDropoffJson     Json      // { mon: {open: "08:00", close: "20:00"}, ... }

  // Pricing
  pricePerNightEgp      Int
  pricePerNightLongStayEgp  Int?  // for 7+ nights, discounted rate
  longStayThresholdNights   Int   @default(7)

  // Requirements (intake checklist)
  requiresVaccinationProof    Boolean   @default(true)
  requiresDewormingProof      Boolean   @default(true)
  requiresHealthCertificate   Boolean   @default(false)
  requiredVaccines            String[]  @default(["rabies", "DHPP", "bordetella"])  // for dogs
  requiredCatVaccines         String[]  @default(["FVRCP", "rabies"])

  // Legal
  liabilityWaiverText         String   @db.Text  // editable per-kennel, defaults to template
  liabilityWaiverVersion      Int      @default(1)

  // Status
  status                KennelStatus @default(PENDING_DOCS)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  units                 KennelUnit[]
  stays                 KennelStay[]

  @@index([status])
  @@map("kennel_profiles")
}

enum KennelFacilityType {
  STANDARD      // basic cages
  LUXURY        // larger runs, outdoor access
  MEDICAL       // for pets with medical needs
  SMALL_DOG_ONLY
  LARGE_DOG_ONLY
}

enum KennelStatus {
  PENDING_DOCS
  APPROVED
  ADMIN_REVIEW
  SUSPENDED
  REJECTED
  DEACTIVATED
}

model KennelUnit {
  id              String    @id @default(cuid())
  kennelProfileId String
  kennelProfile   KennelProfile @relation(fields: [kennelProfileId], references: [id])

  unitNumber      String    // "A-1", "A-2", or whatever numbering kennel uses
  unitType        String    // "STANDARD", "DELUXE", "MEDICAL", etc.
  sizeSquareMeters Decimal? @db.Decimal(6, 2)
  hasOutdoorAccess Boolean  @default(false)
  suitableForSize String[]  @default(["SMALL", "MEDIUM"])  // dog size
  maxOccupancy    Int       @default(1)  // sometimes 2 pets share

  photosUrls      String[]  @default([])
  notes           String?   @db.Text

  isActive        Boolean   @default(true)
  inMaintenanceUntil  DateTime?

  stays           KennelStay[]

  @@index([kennelProfileId])
  @@unique([kennelProfileId, unitNumber])
  @@map("kennel_units")
}

model KennelStay {
  id                  String    @id @default(cuid())
  bookingId           String    @unique
  booking             Booking   @relation(fields: [bookingId], references: [id])
  kennelProfileId     String
  kennelProfile       KennelProfile @relation(fields: [kennelProfileId], references: [id])
  kennelUnitId        String?
  kennelUnit          KennelUnit? @relation(fields: [kennelUnitId], references: [id])

  // Timing
  checkInAt           DateTime
  expectedCheckOutAt  DateTime
  actualCheckInAt     DateTime?
  actualCheckOutAt    DateTime?

  // Intake
  intakePhotos        String[]  @default([])  // Cloudinary URLs
  intakeWeight        Decimal?  @db.Decimal(5, 2)
  intakeNotes         String?   @db.Text
  intakeDoneBy        String?   // team member userId
  intakeDoneAt        DateTime?

  // Documents at intake
  vaccinationDocsUrls String[]  @default([])
  dewormingDocsUrls   String[]  @default([])
  healthCertUrls      String[]  @default([])
  liabilityWaiverSignedAt  DateTime?
  liabilityWaiverVersion   Int?
  liabilityWaiverSignatureUrl  String?  // signed waiver PDF Cloudinary URL

  // Parent-provided food/meds
  foodProvidedByParent Boolean  @default(false)
  medicationsJson      Json?    // array of {name, schedule, dose, notes}

  // Daily logs
  dailyUpdatesJson     Json?    // per-day: {date, mood, appetite, exerciseMinutes, notes, photoUrls}

  // Discharge
  dischargePhotos      String[]  @default([])
  dischargeWeight      Decimal?  @db.Decimal(5, 2)
  dischargeNotes       String?   @db.Text
  dischargeDoneBy      String?
  dischargeDoneAt      DateTime?

  status               KennelStayStatus @default(CONFIRMED)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([kennelProfileId, status])
  @@index([checkInAt])
  @@map("kennel_stays")
}

enum KennelStayStatus {
  CONFIRMED
  AWAITING_INTAKE
  IN_STAY
  READY_FOR_DISCHARGE
  DISCHARGED
  CANCELLED
  MEDICAL_HOLD  // kennel keeping pet longer for medical reason
}

// ============================================================
// PETHOTEL PROFILES (extends Kennel with room types)
// ============================================================

model PetHotelProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business info (same as Kennel)
  businessName       String
  commercialRegister String?
  businessLicense    String?
  taxCardNumber      String?
  ownerName          String?

  businessPhone String?
  businessEmail String?

  // Facility
  addressLine    String?
  city           String?
  district       String?
  lat            Decimal? @db.Decimal(10, 8)
  lng            Decimal? @db.Decimal(11, 8)
  facilityPhotos String[] @default([]) // min 5

  totalCapacity  Int?
  operatingHours Json?
  daysOpen       String[]

  petTypesAccepted String[]
  sizesAccepted    String[]

  // Room types: JSON array of { name, description, photos[], capacity, pricePerNight, amenities[] }
  roomTypes Json @default("[]")

  // Premium amenities (all Kennel amenities + extras)
  amenities String[] // includes: room_service, spa_grooming, webcam, daily_updates, private_play, luxury_bedding, special_diet, puppy_socialization

  hasIsolationArea  Boolean @default(false)
  emergencyVetName  String?
  emergencyVetPhone String?

  extraServices     Json?
  pickupDropoffAvail Boolean @default(false)
  pickupDropoffPrice Decimal? @db.Decimal(8, 2)

  vaccinesRequired   String[]
  requiresAssessment Boolean @default(false)
  requiresTrialDay   Boolean @default(false)

  minStayNights Int?
  maxStayNights Int?

  avgRating    Decimal @default(0.00) @db.Decimal(3, 2)
  totalReviews Int     @default(0)

  verificationStatus VerificationStatus @default(PENDING)
  isVerified         Boolean            @default(false)
  verifiedAt         DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, isActive, isVerified])
  @@index([lat, lng])
  @@map("pethotel_profiles")
}

// ============================================================
// PETS
// ============================================================

model Pet {
  id            String         @id @default(uuid())
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  species       Species
  breed         String?
  nickname      String?
  ageCategory   AgeCategory?
  neuteredStatus NeuteredStatus @default(unknown)
  houseTrained  HouseTrainedStatus @default(yes)
  color         String?
  dateOfBirth   DateTime?      @db.Date
  weightKg      Decimal?       @db.Decimal(5, 2)
  weightCategory WeightCategory?
  gender        PetGender      @default(unknown)
  isNeutered    Boolean        @default(false)

  // Microchip
  hasMicrochip  Boolean  @default(false)
  microchipId   String?

  // Photos — min 2, max 6 required by UI
  profilePhoto  String?
  photos        String[]

  // Vaccination certificate
  vaccinationCertPhoto String?   // uploaded document/photo URL
  vaccinationVerified  Boolean   @default(false) // set by admin after review

  // Special needs
  medicalConditions String? // free text
  specialNotes      String? // free text

  // Feeding schedule: JSON array of { time: "08:00", notes?: string }
  feedingSchedule Json @default("[]")

  // Walking schedule: JSON array of { time: "07:00", durationMinutes?: number }
  walkingSchedule Json @default("[]")

  // Temperament (JSON)
  temperament Json @default("{}") // { goodWithDogs, goodWithCats, goodWithChildren, isAnxious, aggressiveTendencies, notes }

  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  medicalInfo   PetMedicalInfo?
  vaccinations  PetVaccination[]
  medications   PetMedication[]
  behavior      PetBehavior?
  schedules     PetSchedule[]
  bookingPets   BookingPet[]
  petReviews    PetReview[]
  bookingTasks  BookingTask[]
  careLogs      CareLog[]

  @@index([ownerId])
  @@map("pets")
}

model PetMedicalInfo {
  id                    String   @id @default(uuid())
  petId                 String   @unique
  pet                   Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  allergies             String[]
  medicalNotes          String?
  vetName               String?
  vetClinic             String?
  vetPhone              String?
  vetAddress            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRel   String?
  altVetName            String?
  altVetPhone           String?
  updatedAt             DateTime @updatedAt

  @@map("pet_medical_info")
}

model PetVaccination {
  id               String   @id @default(uuid())
  petId            String
  pet              Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  vaccineName      String
  administeredDate DateTime @db.Date
  expiryDate       DateTime? @db.Date
  documentUrl      String?
  notes            String?
  createdById      String?
  createdAt        DateTime @default(now())

  @@index([petId])
  @@index([expiryDate])
  @@map("pet_vaccinations")
}

model PetMedication {
  id             String              @id @default(uuid())
  petId          String
  pet            Pet                 @relation(fields: [petId], references: [id], onDelete: Cascade)
  name           String
  medicationType MedicationType      @default(pill)
  dosage         String?
  unit           String?
  frequency      MedicationFrequency
  adminTimes     String[]            // ["08:00", "20:00"]
  startDate      DateTime?           @db.Date
  endDate        DateTime?           @db.Date
  notes          String?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())

  @@index([petId, isActive])
  @@map("pet_medications")
}

model PetBehavior {
  id               String                @id @default(uuid())
  petId            String                @unique
  pet              Pet                   @relation(fields: [petId], references: [id], onDelete: Cascade)
  temperamentTags  String[]
  goodWithDogs     BehaviorCompatibility @default(yes)
  goodWithCats     BehaviorCompatibility @default(yes)
  goodWithKids     BehaviorCompatibility @default(yes)
  trainingLevel    TrainingLevel         @default(none)
  energyLevel      EnergyLevel           @default(medium)
  behaviorNotes    String?
  fearTriggers     String[]
  updatedAt        DateTime              @updatedAt

  @@map("pet_behavior")
}

model PetSchedule {
  id              String       @id @default(uuid())
  petId           String
  pet             Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  scheduleType    ScheduleType
  scheduledTime   String       // "08:00"
  durationMinutes Int?
  foodType        String?
  foodAmount      String?
  notes           String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([petId, isActive])
  @@map("pet_schedules")
}

model CareLog {
  id            String         @id @default(uuid())
  bookingId     String
  booking       Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  petId         String
  pet           Pet            @relation(fields: [petId], references: [id])
  actionType    CareActionType
  scheduledTime DateTime
  completedAt   DateTime?
  completedById String?
  completedBy   User?          @relation("CareLogCompleter", fields: [completedById], references: [id])
  notes         String?
  createdAt     DateTime       @default(now())

  @@index([bookingId])
  @@index([petId])
  @@map("care_logs")
}

// ============================================================
// BOOKINGS
// ============================================================

model Booking {
  id           String @id @default(uuid())
  parentId     String                                    // was: ownerId
  parent       User   @relation("BookingParent", fields: [parentId], references: [id])
  petFriendId  String?                                   // null for Kennel/Trainer/PetHotel
  petFriend    User?  @relation("BookingPetFriend", fields: [petFriendId], references: [id])

  // Provider references (only one will be set based on serviceType)
  trainerProfileId  String?
  trainerProfile    TrainerProfile? @relation("TrainerBookings", fields: [trainerProfileId], references: [id])
  trainerId    String?
  kennelId     String?
  petHotelId   String?

  // Trainer session/program tracking
  sessionPackageId   String?   // for multi-session bookings
  sessionsCompleted  Int       @default(0)
  sessionsTotal      Int?      // for packages/programs
  trainerNotes       Json?     // [{sessionNum, date, notes, homework}]

  bookingType  BookingType
  serviceType  ServiceType
  status       BookingStatus @default(pending)

  // Timing
  requestedStart DateTime
  requestedEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?

  // Location
  serviceLocationType ServiceLocationType
  serviceLat          Decimal?             @db.Decimal(10, 8)
  serviceLng          Decimal?             @db.Decimal(11, 8)
  serviceAddress      String?

  // Pricing
  basePrice        Decimal @db.Decimal(10, 2)
  commissionRate   Decimal @default(15.00) @db.Decimal(5, 2)
  commissionAmount Decimal @db.Decimal(10, 2)
  totalPrice       Decimal @db.Decimal(10, 2)
  providerPayout   Decimal @db.Decimal(10, 2)  // was: sitterPayout
  currency         String  @default("EGP")

  // Overtime (PetFriend bookings)
  overtimeMinutes Int     @default(0)
  overtimeCharge  Decimal @default(0) @db.Decimal(8, 2)

  // Payment
  paymentStatus       PaymentStatus  @default(pending)
  paymentMethod       PaymentMethod?
  paymentReference    String?
  paymentAuthorizedAt DateTime?
  paymentCapturedAt   DateTime?
  paymentRefundedAt   DateTime?
  refundAmount        Decimal?       @db.Decimal(10, 2)
  refundReason        String?

  // Cancellation
  cancelledById      String?
  cancelledBy        User?            @relation("CancelledBy", fields: [cancelledById], references: [id])
  cancelledAt        DateTime?
  cancellationReason String?
  cancellationType   CancellationType?

  // Pickup
  readyForPickupAt  DateTime?
  pickupConfirmedAt DateTime?

  // Instructions
  specialInstructions String?
  parentNotes         String?  // was: ownerNotes

  // Pet snapshot (frozen at booking time)
  petSnapshot Json? // Array of pet summaries

  // Review
  parentReviewed    Boolean  @default(false)  // was: ownerReviewed
  providerReviewed  Boolean  @default(false)  // was: sitterReviewed
  reviewDeadline    DateTime?

  // Routing
  routingAttempt Int    @default(1)
  routingHistory Json   @default("[]")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  pets              BookingPet[]
  extensions        BookingExtension[]
  dispute           BookingDispute?
  tasks             BookingTask[]
  walkSessions      WalkSession[]
  reviews           Review[]
  transactions      PaymentTransaction[]
  payouts           PetFriendPayout[]
  careLogs          CareLog[]
  overtimeLog       OvertimeLog?
  endCode           BookingEndCode?      // 4-digit service end code
  kennelStay        KennelStay?          // Prompt 12: kennel boarding stay

  @@index([parentId, status, createdAt(sort: Desc)])
  @@index([petFriendId, status, createdAt(sort: Desc)])
  @@index([status, requestedStart])
  @@index([petFriendId])
  @@index([trainerProfileId])
  @@index([paymentStatus])
  @@index([parentId, status])
  @@map("bookings")
}

// 4-digit service end code — shown only to Parent, entered by PetFriend to end service
model BookingEndCode {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  code      String   // 4-digit string e.g. "4821"
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("booking_end_codes")
}

model BookingPet {
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  petId     String
  pet       Pet     @relation(fields: [petId], references: [id])

  @@id([bookingId, petId])
  @@map("booking_pets")
}

model BookingExtension {
  id              String          @id @default(uuid())
  bookingId       String
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requestedById   String
  newEndTime      DateTime
  additionalPrice Decimal?        @db.Decimal(10, 2)
  reason          String?
  status          ExtensionStatus @default(pending)
  respondedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@index([bookingId])
  @@map("booking_extensions")
}

model BookingDispute {
  id              String            @id @default(uuid())
  bookingId       String            @unique
  booking         Booking           @relation(fields: [bookingId], references: [id])
  openedById      String
  reasonCategory  DisputeCategory
  description     String
  evidenceUrls    String[]
  status          DisputeStatus     @default(open)
  resolution      DisputeResolution?
  resolutionNotes String?
  resolvedById    String?
  resolvedAt      DateTime?
  appealDeadline  DateTime?
  parentAmount    Decimal?          @db.Decimal(10, 2)  // was: ownerAmount
  providerAmount  Decimal?          @db.Decimal(10, 2)  // was: sitterAmount
  createdAt       DateTime          @default(now())

  @@index([status, createdAt])
  @@map("booking_disputes")
}

// ============================================================
// CARE TASKS & WALK TRACKING
// ============================================================

model BookingTask {
  id            String     @id @default(uuid())
  bookingId     String
  booking       Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  petId         String?
  pet           Pet?       @relation(fields: [petId], references: [id])
  taskType      TaskType
  taskName      String
  scheduledAt   DateTime
  dueBy         DateTime
  completedAt   DateTime?
  completedById String?
  photoUrl      String?
  notes         String?
  status        TaskStatus @default(pending)
  alertSentToParent Boolean @default(false)  // was: alertSentOwner
  createdAt     DateTime   @default(now())

  walkSession WalkSession?

  @@index([bookingId, status, scheduledAt])
  @@index([scheduledAt, status])
  @@map("booking_tasks")
}

model WalkSession {
  id              String      @id @default(uuid())
  taskId          String      @unique
  task            BookingTask @relation(fields: [taskId], references: [id])
  bookingId       String
  booking         Booking     @relation(fields: [bookingId], references: [id])
  petIds          String[]
  petFriendId     String      // was: sitterId
  startTime       DateTime
  endTime         DateTime?
  totalDistanceM  Int         @default(0)
  durationSeconds Int         @default(0)
  avgSpeedKmh     Decimal?    @db.Decimal(5, 2)
  routeGeoJson    Json?
  isComplete      Boolean     @default(false)
  isFraudFlagged  Boolean     @default(false)
  fraudReason     String?
  createdAt       DateTime    @default(now())

  trackingPoints WalkTrackingPoint[]

  @@index([bookingId])
  @@map("walk_sessions")
}

model WalkTrackingPoint {
  id         String      @id @default(uuid())
  sessionId  String
  session    WalkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lat        Decimal     @db.Decimal(10, 8)
  lng        Decimal     @db.Decimal(11, 8)
  accuracyM  Decimal?    @db.Decimal(7, 2)
  speedMs    Decimal?    @db.Decimal(5, 2)
  altitudeM  Decimal?    @db.Decimal(8, 2)
  recordedAt DateTime
  createdAt  DateTime    @default(now())

  @@index([sessionId, recordedAt])
  @@map("walk_tracking_points")
}

// ============================================================
// PAYMENTS
// ============================================================

model PaymentTransaction {
  id              String               @id @default(uuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id])
  bookingId       String?
  booking         Booking?             @relation(fields: [bookingId], references: [id])
  type            TransactionType
  amount          Decimal              @db.Decimal(10, 2)
  currency        String               @default("EGP")
  direction       TransactionDirection
  status          TransactionStatus    @default(pending)
  gateway         PaymentGateway?
  gatewayRef      String?              @unique
  gatewayResponse Json?
  errorMessage    String?
  retryCount      Int                  @default(0)
  processedAt     DateTime?
  createdAt       DateTime             @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([bookingId])
  @@map("payment_transactions")
}

model PetFriendPayout {
  id             String               @id @default(uuid())
  petFriendId    String               // User id — was: sitterId
  petFriend      User                 @relation("UserPayouts", fields: [petFriendId], references: [id])
  // Link to PetFriendProfile for new payout flows
  petFriendProfileId  String?
  petFriendProfile    PetFriendProfile? @relation("ProfilePayouts", fields: [petFriendProfileId], references: [id])
  bookingId      String?
  booking        Booking?             @relation(fields: [bookingId], references: [id])
  amount         Decimal              @db.Decimal(10, 2)
  payoutMethod   ProviderPayoutMethod
  destination    String?
  status         PayoutStatus         @default(pending)
  // Enhanced payout tracking
  type                  PayoutType    @default(SCHEDULED)
  commissionEgp         Int           @default(0)
  netEgp                Int           @default(0)
  scheduledFor          DateTime?
  requestedAt           DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  bookingsCount         Int           @default(0)
  bookingIds            String[]
  instantCashoutFeeEgp  Int           @default(0)
  gatewayRef     String?
  scheduledAt    DateTime?
  processedAt    DateTime?
  failureReason  String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([petFriendId, status])
  @@index([petFriendProfileId, status])
  @@index([scheduledFor])
  @@map("petfriend_payouts")
}

// ── Trainer Payouts (polymorphic — separate from PetFriendPayout) ──

model TrainerPayout {
  id                   String               @id @default(cuid())
  trainerId            String               // TrainerProfile.id
  trainerProfile       TrainerProfile       @relation(fields: [trainerId], references: [id])
  bookingId            String?
  amount               Decimal              @db.Decimal(10, 2)
  payoutMethod         ProviderPayoutMethod
  destination          String?
  status               PayoutStatus         @default(pending)
  type                 PayoutType           @default(SCHEDULED)
  commissionEgp        Int                  @default(0)
  netEgp               Int                  @default(0)
  scheduledFor         DateTime?
  requestedAt          DateTime?
  completedAt          DateTime?
  failedAt             DateTime?
  bookingsCount        Int                  @default(0)
  bookingIds           String[]
  instantCashoutFeeEgp Int                  @default(0)
  gatewayRef           String?
  failureReason        String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([trainerId, status])
  @@index([scheduledFor])
  @@map("trainer_payouts")
}

model ProcessedWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  provider    String
  processedAt DateTime @default(now())

  @@index([eventId])
  @@map("processed_webhook_events")
}

model PricingBounds {
  id            String   @id @default(cuid())
  serviceType   String   @unique  // "HOUR" | "DAY" | "NIGHT" | "WALK"
  minEgp        Int
  defaultMaxEgp Int      // max for new providers
  eliteMaxEgp   Int      // max for 4.5+ rating & 20+ bookings
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pricing_bounds")
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id           String      @id @default(uuid())
  bookingId    String
  booking      Booking     @relation(fields: [bookingId], references: [id])
  reviewerId   String
  reviewer     User        @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId   String
  reviewee     User        @relation("Reviewee", fields: [revieweeId], references: [id])
  revieweeType RevieweeType

  overallRating        Decimal @db.Decimal(3, 2)

  // Parent reviewing PetFriend/provider
  ratingCommunication  Decimal? @db.Decimal(3, 2)
  ratingReliability    Decimal? @db.Decimal(3, 2)
  ratingCareQuality    Decimal? @db.Decimal(3, 2)
  ratingValue          Decimal? @db.Decimal(3, 2)

  // PetFriend reviewing Parent
  ratingPetBehavior    Decimal? @db.Decimal(3, 2)
  ratingCleanliness    Decimal? @db.Decimal(3, 2)

  comment      String
  wouldRebook  Boolean?
  photos       String[]

  isPublished  Boolean  @default(false)
  isReported   Boolean  @default(false)
  isModerated  Boolean  @default(false)
  moderationAction ModerationAction?
  moderationNote   String?

  submittedAt DateTime @default(now())
  publishedAt DateTime?

  @@index([revieweeId, revieweeType, isPublished])
  @@index([bookingId])
  @@map("reviews")
}

model PetReview {
  id                        String   @id @default(uuid())
  bookingId                 String
  petFriendId               String   // was: sitterId
  petId                     String
  pet                       Pet      @relation(fields: [petId], references: [id])
  behaviorRating            Int
  behaviorNotes             String?
  isVisibleToFuturePetFriends Boolean @default(true)  // was: isVisibleToFutureSitters
  createdAt                 DateTime @default(now())

  @@index([petId])
  @@map("pet_reviews")
}

